<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained win-x64 publish for Inno Setup.

  PublishSingleFile is intentionally OFF: LibVLCSharp loads libvlc.dll from
  disk beside the app host. The single-file host still caused native load
  failures for some users even when libvlc\win-x64 was copied out; a normal
  apphost + loose assemblies matches Debug and is reliable.

  Invoke with:
    dotnet publish MusicWidget\MusicWidget.csproj -c Release ^
      -p:PublishProfile=Properties\PublishProfiles\WinX64SelfContained.pubxml
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>bin\publish\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- Trimming is off: WPF + LibVLCSharp + TagLibSharp use reflection that
         the linker's analyzers can't always see. Safer to ship a slightly
         bigger binary than to chase NullReferenceExceptions in the wild. -->
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>embedded</DebugType>
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>
</Project>
