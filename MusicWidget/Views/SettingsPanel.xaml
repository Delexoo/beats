<UserControl x:Class="MusicWidget.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:MusicWidget.Models"
             xmlns:conv="clr-namespace:MusicWidget.Converters"
             x:Name="SettingsPanelRoot"
             Foreground="{StaticResource Brush.Text}"
             FontFamily="{StaticResource Font.Body}"
             FontSize="13"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
  <UserControl.Resources>
    <conv:ZoomMultiplyConverter x:Key="ZoomMultiply"/>
    <conv:ZoomThicknessConverter x:Key="ZoomThickness"/>

    <!-- Dashboard chrome: minimal section labels and quiet toolbar controls -->
    <Style x:Key="DashboardSectionLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DashboardToolbarButton" TargetType="Button" BasedOn="{StaticResource IconGhostButton}">
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <Style x:Key="DashboardOutlineButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
      <Setter Property="Padding" Value="11,6"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
          <Setter Property="BorderBrush" Value="#FF3A4454"/>
          <Setter Property="Background" Value="#0DFFFFFF"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DashboardTitle" TargetType="TextBlock" BasedOn="{StaticResource PageTitle}">
      <Setter Property="FontSize" Value="17"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="PlaylistAddMusicButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="Margin" Value="0,6,0,2"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid SnapsToDevicePixels="True">
              <Rectangle x:Name="outline"
                         RadiusX="8"
                         RadiusY="8"
                         Stroke="#FF3A4454"
                         StrokeThickness="1"
                         StrokeDashArray="3 3"
                         Fill="Transparent"/>
              <ContentPresenter Margin="14,12"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="outline" Property="Fill" Value="#0AFFFFFF"/>
                <Setter TargetName="outline" Property="Stroke" Value="#FF556070"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="outline" Property="Fill" Value="#12FFFFFF"/>
                <Setter TargetName="outline" Property="Stroke" Value="#FF64748B"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PlaylistRowIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconGhostButton}">
      <Setter Property="Width" Value="27"/>
      <Setter Property="Height" Value="27"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="PlaylistRowIconPathStyle" TargetType="Path">
      <Setter Property="Fill" Value="{StaticResource Brush.TextDim}"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
          <Setter Property="Fill" Value="White"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- Outer playlist list: allow each row to grow when expanded. -->
    <Style x:Key="PlaylistAccordionListBox" TargetType="ListBox" BasedOn="{StaticResource DarkListBox}">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="VirtualizingPanel.IsVirtualizing" Value="False"/>
      <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="PlaylistListItem_PreviewMouseLeftButtonDown"/>
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                  <Border x:Name="bg"
                          Background="{TemplateBinding Background}"
                          BorderBrush="Transparent"
                          BorderThickness="0"
                          CornerRadius="8"
                          Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="bg" Property="Background" Value="#FF181D25"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                      <Setter TargetName="bg" Property="Background" Value="#FF1A2028"/>
                      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Style.Triggers>
              <DataTrigger Binding="{Binding}" Value="{x:Static models:PlaylistDivider.Instance}">
                <Setter Property="IsHitTestVisible" Value="False"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Inline track list under an expanded playlist. -->
    <Style x:Key="NestedTracksListBox" TargetType="ListBox">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="MaxHeight" Value="400"/>
      <Setter Property="VirtualizingPanel.IsVirtualizing" Value="False"/>
      <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
      <Setter Property="ItemsPanel">
        <Setter.Value>
          <ItemsPanelTemplate>
            <StackPanel/>
          </ItemsPanelTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBox">
            <ScrollViewer Padding="{TemplateBinding Padding}"
                          Focusable="False"
                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
              <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
            </ScrollViewer>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                  <Border x:Name="bg"
                          Background="{TemplateBinding Background}"
                          CornerRadius="6"
                          Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="bg" Property="Background" Value="#FF181D25"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                      <Setter TargetName="bg" Property="Background" Value="#FF1E2430"/>
                      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Add-music drop zone menu (opened from the dotted button under a playlist). -->
    <ContextMenu x:Key="PlaylistAddMusicContextMenu"
                 Opened="PlaylistAddMusicMenu_Opened">
      <MenuItem Header="Add files"
                Click="PlaylistContextAddFiles_Click">
        <MenuItem.Icon>
          <Path Data="{StaticResource Icon.Plus}"
                Fill="{StaticResource Brush.Text}"
                Stretch="Uniform"
                Width="13" Height="13"/>
        </MenuItem.Icon>
      </MenuItem>
      <MenuItem Header="Add folder"
                Click="PlaylistContextAddFolder_Click">
        <MenuItem.Icon>
          <Path Data="{StaticResource Icon.Folder}"
                Fill="{StaticResource Brush.Text}"
                Stretch="Uniform"
                Width="13" Height="13"/>
        </MenuItem.Icon>
      </MenuItem>
      <MenuItem Header="Paste audio link"
                Click="PlaylistContextDownload_Click">
        <MenuItem.Icon>
          <Path Data="{StaticResource Icon.Download}"
                Fill="{StaticResource Brush.Blue}"
                Stretch="Uniform"
                Width="13" Height="13"/>
        </MenuItem.Icon>
      </MenuItem>
    </ContextMenu>

    <!-- Shared context menu for tracks (used by all nested track lists). -->
    <ContextMenu x:Key="TrackContextMenu"
                 Opened="TrackContextMenu_Opened">
      <MenuItem Header="Play"
                Click="TrackContextPlay_Click">
        <MenuItem.Icon>
          <Path Data="{StaticResource Icon.Play}"
                Fill="{StaticResource Brush.Text}"
                Stretch="Uniform"
                Width="12" Height="12"/>
        </MenuItem.Icon>
      </MenuItem>
      <Separator/>
      <MenuItem Header="Add to Liked Songs"
                Tag="like"
                Click="TrackContextLike_Click">
        <MenuItem.Icon>
          <Path Data="{StaticResource Icon.Heart}"
                Fill="#FFEF4444"
                Stretch="Uniform"
                Width="13" Height="13"/>
        </MenuItem.Icon>
      </MenuItem>
      <Separator/>
      <MenuItem Header="Show in File Explorer"
                Click="TrackContextShowInExplorer_Click">
        <MenuItem.Icon>
          <Path Data="{StaticResource Icon.Folder}"
                Fill="{StaticResource Brush.Text}"
                Stretch="Uniform"
                Width="13" Height="13"/>
        </MenuItem.Icon>
      </MenuItem>
      <MenuItem Header="Copy file path"
                Click="TrackContextCopyPath_Click">
        <MenuItem.Icon>
          <Path Data="{StaticResource Icon.Link}"
                Fill="{StaticResource Brush.Text}"
                Stretch="Uniform"
                Width="13" Height="13"/>
        </MenuItem.Icon>
      </MenuItem>
      <Separator Tag="before-edit"/>
      <MenuItem Header="Edit..."
                Tag="edit"
                Click="TrackContextEdit_Click">
        <MenuItem.Icon>
          <Path Data="{StaticResource Icon.Edit}"
                Fill="{StaticResource Brush.Text}"
                Stretch="Uniform"
                Width="13" Height="13"/>
        </MenuItem.Icon>
      </MenuItem>
      <MenuItem Header="Delete from playlist"
                Tag="delete"
                Click="TrackContextDelete_Click">
        <MenuItem.Icon>
          <Path Data="{StaticResource Icon.Trash}"
                Fill="#FFEF4444"
                Stretch="Uniform"
                Width="13" Height="13"/>
        </MenuItem.Icon>
      </MenuItem>
    </ContextMenu>

    <DataTemplate x:Key="TrackRowTemplate" DataType="{x:Type models:Track}">
      <Grid Background="Transparent"
            Margin="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomThickness}, ConverterParameter='0,0.5,0,0.5'}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0"
                Width="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=33}"
                Height="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=33}"
                CornerRadius="6"
                Background="{StaticResource Brush.SurfaceHigh}"
                ClipToBounds="True"
                Margin="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomThickness}, ConverterParameter='0,0,7,0'}">
          <Grid>
            <TextBlock Text="{Binding Initials}"
                       Foreground="{StaticResource Brush.TextDim}"
                       FontWeight="SemiBold"
                       FontSize="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=12}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding HasArtwork}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <Image Source="{Binding ArtworkSource, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Visibility="Collapsed">
              <Image.Style>
                <Style TargetType="Image">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding HasArtwork}" Value="True">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Image.Style>
            </Image>
          </Grid>
        </Border>
        <TextBlock Grid.Column="1"
                   Text="{Binding FriendlyDisplayName}"
                   Foreground="{StaticResource Brush.Text}"
                   FontSize="13.5"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Margin="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomThickness}, ConverterParameter='0,0,4,0'}"/>
        <Path Grid.Column="2"
              Data="{StaticResource Icon.Heart}"
              Fill="#FFEF4444"
              Stretch="Uniform"
              VerticalAlignment="Center"
              Width="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=13}"
              Height="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=13}"
              Visibility="Collapsed">
          <Path.Style>
            <Style TargetType="Path">
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsLiked}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Path.Style>
        </Path>
      </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:Playlist}">
      <Grid Background="Transparent">
        <Grid.ContextMenu>
          <ContextMenu Opened="PlaylistContextMenu_Opened">
            <MenuItem Header="Play"
                      Click="PlaylistContextPlay_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Play}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="12" Height="12"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem x:Name="PlaylistMenuItemPin"
                      Header="Pin playlist"
                      Click="PlaylistContextPin_Click">
              <MenuItem.Icon>
                <Path x:Name="PlaylistMenuItemPinIcon"
                      Data="{StaticResource Icon.Pin}"
                      Fill="{StaticResource Brush.Blue}"
                      Stretch="Uniform"
                      Width="13" Height="13"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Add files…"
                      Click="PlaylistContextAddFiles_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Plus}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="12" Height="12"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Add folder…"
                      Click="PlaylistContextAddFolder_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Folder}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="13" Height="13"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Paste audio link…"
                      Click="PlaylistContextDownload_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Download}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="13" Height="13"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Open folder in File Explorer"
                      Click="PlaylistContextOpenFolder_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Folder}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="13" Height="13"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Rename…"
                      Click="PlaylistContextRename_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Edit}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="13" Height="13"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Delete playlist"
                      Click="PlaylistContextDelete_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Trash}"
                      Fill="#FFEF4444"
                      Stretch="Uniform"
                      Width="13" Height="13"/>
              </MenuItem.Icon>
            </MenuItem>
          </ContextMenu>
        </Grid.ContextMenu>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0"
              MinHeight="36">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Border Grid.ColumnSpan="4"
                  Background="Transparent"
                  Cursor="Hand"
                  PreviewMouseLeftButtonDown="PlaylistRow_PreviewMouseLeftButtonDown"/>
          <Button Grid.Column="0"
                  Panel.ZIndex="1"
                  Style="{StaticResource PlaylistRowIconButtonStyle}"
                  Click="PlaylistPlayButton_Click"
                  Tag="{Binding}"
                  Margin="0,0,4,0">
          <Button.ToolTip>
            <ToolTip>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Play playlist from the start"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsPlayingNow}" Value="True">
                        <Setter Property="Text" Value="Pause"/>
                      </DataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsActivePlaylist}" Value="True"/>
                          <Condition Binding="{Binding IsPlayingNow}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="Resume"/>
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </ToolTip>
          </Button.ToolTip>
          <Path Stretch="Uniform" Width="12" Height="12">
            <Path.Style>
              <Style TargetType="Path" BasedOn="{StaticResource PlaylistRowIconPathStyle}">
                <Setter Property="Data" Value="{StaticResource Icon.Play}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPlayingNow}" Value="True">
                    <Setter Property="Data" Value="{StaticResource Icon.Pause}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Path.Style>
          </Path>
        </Button>

        <!-- Pinned badge: heart for Liked, download for Saves, pin for user-pinned normals. -->
        <Path Grid.Column="1"
              Panel.ZIndex="1"
              x:Name="PinnedBadge"
              Stretch="Uniform"
              Width="12" Height="12"
              Margin="0,0,6,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              IsHitTestVisible="False"
              Visibility="Collapsed">
          <Path.Style>
            <Style TargetType="Path">
              <Setter Property="Fill" Value="{StaticResource Brush.Blue}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Liked">
                  <Setter Property="Fill" Value="#FFEF4444"/>
                  <Setter Property="Data" Value="{StaticResource Icon.Heart}"/>
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Saves">
                  <Setter Property="Fill" Value="{StaticResource Brush.Blue}"/>
                  <Setter Property="Data" Value="{StaticResource Icon.Download}"/>
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Kind}" Value="Normal"/>
                    <Condition Binding="{Binding IsPinned}" Value="True"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Fill" Value="{StaticResource Brush.Blue}"/>
                  <Setter Property="Data" Value="{StaticResource Icon.Pin}"/>
                  <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </Path.Style>
        </Path>

        <StackPanel Grid.Column="2"
                    Panel.ZIndex="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,8,0"
                    IsHitTestVisible="False">
          <TextBlock Text="{Binding Name}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="240"
                     IsHitTestVisible="False">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="FontSize" Value="14"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <TextBlock VerticalAlignment="Center"
                     Margin="8,0,0,0"
                     FontSize="12"
                     Foreground="{StaticResource Brush.TextMuted}"
                     IsHitTestVisible="False">
            <TextBlock.Text>
              <Binding Path="Tracks.Count" StringFormat="{}{0} songs"/>
            </TextBlock.Text>
          </TextBlock>
        </StackPanel>

        <!-- Rename / Delete / Add — shown for all real (Normal) playlists, even if
             the user has pinned them. Hidden only for virtual Liked/Saves. -->
        <StackPanel Grid.Column="3"
                    Panel.ZIndex="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Visible"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Liked">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Saves">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <Button Style="{StaticResource PlaylistRowIconButtonStyle}"
                  ToolTip="Rename playlist"
                  Click="PlaylistRenameButton_Click"
                  Tag="{Binding}">
            <Path Data="{StaticResource Icon.Edit}"
                  Style="{StaticResource PlaylistRowIconPathStyle}"
                  Stretch="Uniform"
                  Width="13" Height="13"/>
          </Button>
          <Button Style="{StaticResource PlaylistRowIconButtonStyle}"
                  ToolTip="Delete playlist"
                  Click="PlaylistDeleteButton_Click"
                  Tag="{Binding}">
            <Path Data="{StaticResource Icon.Trash}"
                  Style="{StaticResource PlaylistRowIconPathStyle}"
                  Stretch="Uniform"
                  Width="13" Height="13"/>
          </Button>
          <Button Style="{StaticResource PlaylistRowIconButtonStyle}"
                  ToolTip="Add music or download into this playlist"
                  Click="PlaylistAddButton_Click"
                  Tag="{Binding}">
            <Path Data="{StaticResource Icon.Plus}"
                  Style="{StaticResource PlaylistRowIconPathStyle}"
                  Stretch="Uniform"
                  Width="13" Height="13"/>
          </Button>
        </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="30,4,4,2"
                Background="Transparent"
                BorderThickness="0"
                Padding="0">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                               Value="True"/>
                    <Condition Binding="{Binding IsExpanded}" Value="True"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <StackPanel>
            <Border Background="Transparent"
                    BorderThickness="0"
                    Padding="0,2,0,0"
                    Margin="0,0,0,0">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Visible"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Tracks.Count}" Value="0">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <ListBox x:Name="PlaylistTracksList"
                       Style="{StaticResource NestedTracksListBox}"
                       ItemTemplate="{StaticResource TrackRowTemplate}"
                       ItemsSource="{Binding Tracks}"
                       AllowDrop="True"
                       PreviewMouseLeftButtonDown="TracksList_PreviewMouseLeftButtonDown"
                       PreviewMouseLeftButtonUp="TracksList_PreviewMouseLeftButtonUp"
                       PreviewMouseMove="TracksList_PreviewMouseMove"
                       DragOver="TracksList_DragOver"
                       Drop="TracksList_Drop"
                       PreviewMouseWheel="TracksList_PreviewMouseWheel"
                       MouseDoubleClick="TracksList_MouseDoubleClick"
                       PreviewMouseRightButtonDown="TracksList_PreviewMouseRightButtonDown"
                       ContextMenu="{StaticResource TrackContextMenu}"/>
            </Border>

            <Grid>
              <Grid.Style>
                <Style TargetType="Grid">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Kind}" Value="Liked">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Kind}" Value="Saves">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Grid.Style>
              <Button Style="{StaticResource PlaylistAddMusicButtonStyle}"
                      Click="PlaylistAddButton_Click"
                      Tag="{Binding}"
                      ToolTip="Add files, folders, or paste a download link">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <Path Data="{StaticResource Icon.Plus}"
                        Fill="{StaticResource Brush.TextDim}"
                        Stretch="Uniform"
                        Width="13"
                        Height="13"/>
                  <TextBlock Text="Add music"
                             Margin="8,0,0,0"
                             Foreground="{StaticResource Brush.TextMuted}"
                             FontSize="12"
                             FontWeight="Medium"/>
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

    <!-- Divider row between pinned and normal playlists -->
    <DataTemplate DataType="{x:Type models:PlaylistDivider}">
      <Grid Background="Transparent"
            Margin="0,8,0,8"
            IsHitTestVisible="False">
        <Border Height="1"
                Background="{StaticResource Brush.Border}"
                Opacity="0.35"
                Margin="8,0,8,0"/>
      </Grid>
    </DataTemplate>
  </UserControl.Resources>

  <Grid Margin="16,14,16,14">

    <!-- View container: only one of these is visible at a time -->
    <Grid x:Name="ViewContainer">

      <!-- ================== HOME VIEW ================== -->
      <Grid x:Name="HomeView" Visibility="Visible">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Dashboard"
                       Style="{StaticResource DashboardTitle}"/>
            <TextBlock Text="Your library and playback controls"
                       Foreground="{StaticResource Brush.TextMuted}"
                       FontSize="12"
                       Margin="0,2,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      VerticalAlignment="Center">
            <Button x:Name="ResetLayoutButton"
                    Style="{StaticResource DashboardToolbarButton}"
                    ToolTip="Reset layout"
                    Click="ResetLayout_Click">
              <Path Data="{StaticResource Icon.Refresh}"
                    Fill="{StaticResource Brush.TextDim}"
                    Stretch="Uniform"
                    Width="15" Height="15"/>
            </Button>
            <Button x:Name="UpdateButton"
                    Style="{StaticResource DashboardToolbarButton}"
                    Margin="2,0,0,0"
                    Visibility="Collapsed"
                    ToolTip="Check for updates"
                    Click="UpdateButton_Click">
              <Path x:Name="UpdateButtonIcon"
                    Data="{StaticResource Icon.Download}"
                    Fill="{StaticResource Brush.TextDim}"
                    Stretch="Uniform"
                    Width="15" Height="15"/>
            </Button>
            <Button Style="{StaticResource DashboardOutlineButton}"
                    Margin="6,0,0,0"
                    Content="Help"
                    Click="OpenHelp_Click"/>
            <Button Style="{StaticResource DashboardOutlineButton}"
                    Margin="6,0,0,0"
                    Content="Donate"
                    Click="Donate_Click"/>
            <Button Style="{StaticResource DashboardToolbarButton}"
                    Margin="2,0,0,0"
                    ToolTip="Minimize dashboard"
                    Click="MinimizeWidget_Click">
              <Path Data="{StaticResource Icon.Minimize}"
                    Stretch="Uniform"
                    Width="13" Height="13"
                    Stroke="{StaticResource Brush.TextDim}"
                    StrokeThickness="2"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"/>
            </Button>
            <Button Style="{StaticResource DashboardToolbarButton}"
                    Margin="6,0,0,0"
                    ToolTip="Close Beats"
                    Click="ExitApp_Click">
              <Path Data="{StaticResource Icon.Close}"
                    Fill="{StaticResource Brush.TextDim}"
                    Stretch="Uniform"
                    Width="13" Height="13"/>
            </Button>
          </StackPanel>
        </Grid>

        <Border x:Name="BackgroundDownloadBanner"
                Grid.Row="1"
                Visibility="Collapsed"
                Margin="0,0,0,12"
                Background="Transparent"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="0,0,0,10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock x:Name="BackgroundDownloadTitle"
                         Text="Downloading in background"
                         FontWeight="SemiBold"
                         FontSize="13"
                         Foreground="{StaticResource Brush.Text}"/>
              <TextBlock x:Name="BackgroundDownloadDetail"
                         FontSize="11"
                         Foreground="{StaticResource Brush.TextDim}"
                         Margin="0,2,0,6"
                         TextTrimming="CharacterEllipsis"/>
              <ProgressBar x:Name="BackgroundDownloadProgress"
                           Height="4"
                           Minimum="0"
                           Maximum="100"
                           Foreground="{StaticResource Brush.Blue}"
                           Background="{StaticResource Brush.SurfaceHigh}"
                           BorderThickness="0"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
              <TextBlock x:Name="BackgroundDownloadPercent"
                         HorizontalAlignment="Right"
                         FontSize="11.5"
                         Foreground="{StaticResource Brush.TextDim}"/>
              <Button x:Name="BackgroundDownloadCancelButton"
                      Style="{StaticResource FlatButton}"
                      Content="Cancel"
                      Padding="9,4"
                      Margin="0,6,0,0"
                      FontSize="11"
                      HorizontalAlignment="Right"
                      ToolTip="Stop this download"
                      Click="BackgroundDownloadCancel_Click"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Playlists -->
        <Grid Grid.Row="2">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="PLAYLISTS"
                       Style="{StaticResource DashboardSectionLabel}"/>
          </Grid>

          <ScrollViewer x:Name="PlaylistsScrollViewer"
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
              <ListBox x:Name="PlaylistsList"
                       Style="{StaticResource PlaylistAccordionListBox}"
                       ScrollViewer.VerticalScrollBarVisibility="Disabled"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                       SelectionChanged="PlaylistsList_SelectionChanged"/>

              <Button Margin="0,8,0,0"
                      Style="{StaticResource PlaylistAddMusicButtonStyle}"
                      Click="NewPlaylist_Click"
                      ToolTip="Create a new playlist">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <Path Data="{StaticResource Icon.Plus}"
                        Fill="{StaticResource Brush.TextDim}"
                        Stretch="Uniform"
                        Width="13"
                        Height="13"/>
                  <TextBlock Text="New playlist"
                             Margin="8,0,0,0"
                             Foreground="{StaticResource Brush.TextMuted}"
                             FontSize="12"
                             FontWeight="Medium"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </ScrollViewer>
        </Grid>

        <!-- ============================================================ -->
        <!-- Now Playing footer (cover, title/artist, transport, volume)   -->
        <!-- ============================================================ -->
        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Background="Transparent"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="175"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*" MinWidth="175"/>
            </Grid.ColumnDefinitions>

            <!-- Left: cover + title/artist + like + save -->
            <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MaxWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0"
                      Width="48" Height="48"
                      CornerRadius="6"
                      Background="{StaticResource Brush.SurfaceHigh}"
                      ClipToBounds="True">
                <Grid>
                  <TextBlock x:Name="NowPlayingInitials"
                             Text=""
                             Foreground="{StaticResource Brush.TextDim}"
                             FontFamily="{StaticResource Font.Display}"
                             FontWeight="SemiBold"
                             FontSize="17"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                  <!-- Rectangle + ImageBrush: see Track DataTemplate above for the
                       rationale. Guarantees a center-cropped cover no matter the
                       source aspect ratio. -->
                  <Rectangle x:Name="NowPlayingArt"
                             RadiusX="6"
                             RadiusY="6"
                             Visibility="Collapsed"
                             RenderOptions.BitmapScalingMode="HighQuality">
                    <Rectangle.Fill>
                      <ImageBrush x:Name="NowPlayingArtBrush"
                                  Stretch="UniformToFill"
                                  AlignmentX="Center"
                                  AlignmentY="Center"/>
                    </Rectangle.Fill>
                  </Rectangle>
                </Grid>
              </Border>
              <StackPanel Grid.Column="1"
                          Margin="11,0,0,0"
                          VerticalAlignment="Center">
                <TextBlock x:Name="NowPlayingTitle"
                           Text="Nothing playing"
                           Foreground="{StaticResource Brush.Text}"
                           FontFamily="{StaticResource Font.Body}"
                           FontWeight="SemiBold"
                           FontSize="13.5"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="NowPlayingArtist"
                           Text=""
                           Foreground="{StaticResource Brush.TextDim}"
                           FontFamily="{StaticResource Font.Body}"
                           FontSize="12"
                           Margin="0,2,0,0"
                           TextTrimming="CharacterEllipsis"/>
              </StackPanel>

              <!-- Like / Save toggles for the current track. -->
              <Button Grid.Column="2"
                      x:Name="FooterLikeButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="31" Height="31"
                      Margin="8,0,0,0"
                      Click="FooterLike_Click">
                <Button.ToolTip>
                  <ToolTip>
                    <TextBlock x:Name="FooterLikeTooltip" Text="Add to Liked Songs"/>
                  </ToolTip>
                </Button.ToolTip>
                <Path x:Name="FooterLikeIcon"
                      Data="{StaticResource Icon.Heart}"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="14" Height="14"/>
              </Button>
              <Button Grid.Column="3"
                      x:Name="FooterSaveButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="31" Height="31"
                      Margin="3,0,0,0"
                      Click="FooterSave_Click">
                <Button.ToolTip>
                  <ToolTip>
                    <TextBlock x:Name="FooterSaveTooltip" Text="Add to Saves"/>
                  </ToolTip>
                </Button.ToolTip>
                <Path x:Name="FooterSaveIcon"
                      Data="{StaticResource Icon.Download}"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="14" Height="14"/>
              </Button>
            </Grid>

            <!-- Center: shuffle / previous / play-pause / next / loop -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
              <Button x:Name="ShuffleButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="33" Height="33"
                      Margin="0,0,4,0"
                      ToolTip="Shuffle"
                      Click="ShuffleButton_Click">
                <Path x:Name="ShuffleIcon"
                      Data="{StaticResource Icon.Shuffle}"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="15" Height="15"/>
              </Button>
              <Button x:Name="FooterPrevButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="33" Height="33"
                      ToolTip="Previous"
                      Click="FooterPrev_Click">
                <Path Data="{StaticResource Icon.Previous}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="15" Height="15"/>
              </Button>
              <Button x:Name="FooterPlayPauseButton"
                      Style="{StaticResource BlueCircleButton}"
                      Width="42" Height="42"
                      Margin="8,0"
                      Click="FooterPlayPause_Click">
                <Button.ToolTip>
                  <ToolTip>
                    <TextBlock x:Name="FooterPlayPauseTooltip" Text="Play"/>
                  </ToolTip>
                </Button.ToolTip>
                <Path x:Name="FooterPlayPauseIcon"
                      Data="{StaticResource Icon.Play}"
                      Fill="White"
                      Stretch="Uniform"
                      Width="15" Height="15"/>
              </Button>
              <Button x:Name="FooterNextButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="33" Height="33"
                      ToolTip="Next"
                      Click="FooterNext_Click">
                <Path Data="{StaticResource Icon.Next}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="15" Height="15"/>
              </Button>
              <Button x:Name="FooterLoopButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="33" Height="33"
                      Margin="4,0,0,0"
                      Click="FooterLoop_Click">
                <Button.ToolTip>
                  <ToolTip>
                    <TextBlock x:Name="FooterLoopTooltip" Text="Loop: OFF"/>
                  </ToolTip>
                </Button.ToolTip>
                <Grid Width="15" Height="15">
                  <Rectangle x:Name="FooterLoopIconRect">
                    <Rectangle.Fill>
                      <SolidColorBrush Color="#94A3B8"/>
                    </Rectangle.Fill>
                    <Rectangle.OpacityMask>
                      <ImageBrush ImageSource="pack://application:,,,/Assets/loop.png"
                                  Stretch="Uniform"/>
                    </Rectangle.OpacityMask>
                  </Rectangle>
                </Grid>
              </Button>
            </StackPanel>

            <!-- Right: volume + progress -->
            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        MinWidth="220">
              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Right">
                <Button x:Name="FooterMuteButton"
                        Style="{StaticResource PlaylistRowIconButtonStyle}"
                        Width="28" Height="28"
                        Margin="0,0,6,0"
                        Click="FooterMute_Click"
                        ToolTip="Mute / unmute">
                  <Path x:Name="FooterVolumeIcon"
                        Data="{StaticResource Icon.Volume}"
                        Fill="{StaticResource Brush.TextDim}"
                        Stretch="Uniform"
                        Width="15" Height="15"/>
                </Button>
                <Slider x:Name="FooterVolumeSlider"
                        Width="120"
                        Minimum="0"
                        Maximum="100"
                        SmallChange="1"
                        LargeChange="10"
                        Value="80"
                        VerticalAlignment="Center"
                        IsMoveToPointEnabled="True"
                        ValueChanged="FooterVolume_ValueChanged"
                        ToolTip="Volume"/>
              </StackPanel>
              <Grid Margin="0,6,0,0"
                    HorizontalAlignment="Stretch"
                    MinWidth="220"
                    Width="240">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterPositionLabel"
                           Grid.Column="0"
                           Text="0:00"
                           Foreground="{StaticResource Brush.TextDim}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="11.5"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Slider x:Name="FooterProgressSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="1"
                        Value="0"
                        VerticalAlignment="Center"
                        IsMoveToPointEnabled="True"
                        ValueChanged="FooterProgress_ValueChanged"
                        ToolTip="Seek"/>
                <TextBlock x:Name="FooterDurationLabel"
                           Grid.Column="2"
                           Text="0:00"
                           Foreground="{StaticResource Brush.TextDim}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="11.5"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
              </Grid>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <!-- ================== HELP HUB ================== -->
      <Grid x:Name="HelpView" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0"
                  Style="{StaticResource IconGhostButton}"
                  ToolTip="Back"
                  Click="NavBack_Click">
            <Path Data="{StaticResource Icon.Back}"
                  Fill="{StaticResource Brush.Text}"
                  Stretch="Uniform"
                  Width="15" Height="15"/>
          </Button>
          <TextBlock Grid.Column="1"
                     Text="Are you stuck?"
                     Style="{StaticResource PageTitle}"
                     Margin="8,0,0,0"/>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20">
          <StackPanel>
            <TextBlock Text="How can we help?"
                       Foreground="{StaticResource Brush.Text}"
                       FontWeight="SemiBold"
                       FontSize="17"/>
            <TextBlock Text="Pick a section to learn more about the widget."
                       Foreground="{StaticResource Brush.TextDim}"
                       FontSize="13"
                       Margin="0,3,0,18"/>

            <Button Style="{StaticResource NavCardButton}"
                    Margin="0,0,0,10"
                    ToolTip="Get music playing in four steps"
                    Click="OpenQuickStart_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{StaticResource Brush.Blue}"
                        CornerRadius="10"
                        Width="40" Height="40"
                        Margin="0,0,12,0">
                  <Path Data="{StaticResource Icon.Play}"
                        Fill="White"
                        Stretch="Uniform"
                        Width="16" Height="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Quick start"
                             Foreground="{StaticResource Brush.Text}"
                             FontWeight="SemiBold"
                             FontSize="14"/>
                  <TextBlock Text="Create a playlist and start listening."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="12"
                             Margin="0,2,0,0"/>
                </StackPanel>
                <Path Grid.Column="2"
                      Data="M 8.59,16.59 L 13.17,12 L 8.59,7.41 L 10,6 L 16,12 L 10,18 z"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Style="{StaticResource NavCardButton}"
                    Margin="0,0,0,10"
                    ToolTip="YouTube cookie file for yt-dlp when browser import fails"
                    Click="OpenYoutubeCookies_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{StaticResource Brush.Blue}"
                        CornerRadius="10"
                        Width="40" Height="40"
                        Margin="0,0,12,0">
                  <Path Data="{StaticResource Icon.Link}"
                        Fill="White"
                        Stretch="Uniform"
                        Width="14" Height="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Download cookies"
                             Foreground="{StaticResource Brush.Text}"
                             FontWeight="SemiBold"
                             FontSize="14"/>
                  <TextBlock Text="Optional cookies.txt for YouTube, Instagram, and blocked links."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="12"
                             Margin="0,2,0,0"/>
                </StackPanel>
                <Path Grid.Column="2"
                      Data="M 8.59,16.59 L 13.17,12 L 8.59,7.41 L 10,6 L 16,12 L 10,18 z"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Style="{StaticResource NavCardButton}"
                    Margin="0,0,0,10"
                    ToolTip="Keyboard and mouse shortcuts"
                    Click="OpenShortcuts_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{StaticResource Brush.Blue}"
                        CornerRadius="10"
                        Width="40" Height="40"
                        Margin="0,0,12,0">
                  <Path Data="{StaticResource Icon.Bolt}"
                        Fill="White"
                        Stretch="Uniform"
                        Width="14" Height="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Shortcuts"
                             Foreground="{StaticResource Brush.Text}"
                             FontWeight="SemiBold"
                             FontSize="14"/>
                  <TextBlock Text="Hotkeys and quick gestures."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="12"
                             Margin="0,2,0,0"/>
                </StackPanel>
                <Path Grid.Column="2"
                      Data="M 8.59,16.59 L 13.17,12 L 8.59,7.41 L 10,6 L 16,12 L 10,18 z"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Style="{StaticResource NavCardButton}"
                    ToolTip="Open delexo.store in your browser"
                    Click="OpenMorePrograms_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{StaticResource Brush.Blue}"
                        CornerRadius="10"
                        Width="40" Height="40"
                        Margin="0,0,12,0">
                  <Path Data="{StaticResource Icon.Apps}"
                        Fill="White"
                        Stretch="Uniform"
                        Width="15" Height="15"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="More Programs"
                             Foreground="{StaticResource Brush.Text}"
                             FontWeight="SemiBold"
                             FontSize="14"/>
                  <TextBlock Text="Browse other tools at delexo.store."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="12"
                             Margin="0,2,0,0"/>
                </StackPanel>
                <Path Grid.Column="2"
                      Data="M 14,3 V 5 H 17.59 L 7.76,14.83 L 9.17,16.24 L 19,6.41 V 10 H 21 V 3 z M 19,19 H 5 V 5 H 12 V 3 H 5 c -1.11,0 -2,0.9 -2,2 V 19 a 2,2 0 0 0 2,2 H 19 a 2,2 0 0 0 2,-2 V 12 H 19 V 19 z"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"/>
              </Grid>
            </Button>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ================== QUICK START SUB-PAGE ================== -->
      <Grid x:Name="QuickStartView" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0"
                  Style="{StaticResource IconGhostButton}"
                  ToolTip="Back"
                  Click="NavBack_Click">
            <Path Data="{StaticResource Icon.Back}"
                  Fill="{StaticResource Brush.Text}"
                  Stretch="Uniform"
                  Width="15" Height="15"/>
          </Button>
          <TextBlock Grid.Column="1"
                     Text="Quick start"
                     Style="{StaticResource PageTitle}"
                     Margin="8,0,0,0"/>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,20,22,20">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

              <TextBlock Text="Get music playing"
                         Foreground="{StaticResource Brush.Text}"
                         FontWeight="SemiBold"
                         FontSize="17"/>
              <TextBlock Text="Four simple steps."
                         Foreground="{StaticResource Brush.TextDim}"
                         FontSize="13"
                         Margin="0,3,0,22"/>

              <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource Brush.Blue}"
                        CornerRadius="16"
                        Width="33" Height="33"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                  <TextBlock Text="1" Foreground="White" FontFamily="{StaticResource Font.Display}" FontWeight="Bold" FontSize="15"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Create a playlist"
                             FontWeight="SemiBold" FontSize="14"
                             Foreground="{StaticResource Brush.Text}"/>
                  <TextBlock Text="Click &#x201C;New Playlist&#x201D; at the top of the list and give it a name."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="13" LineHeight="20" TextWrapping="Wrap"
                             Margin="0,5,0,0"/>
                </StackPanel>
              </Grid>

              <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource Brush.Blue}"
                        CornerRadius="16"
                        Width="33" Height="33"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                  <TextBlock Text="2" Foreground="White" FontFamily="{StaticResource Font.Display}" FontWeight="Bold" FontSize="15"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Open the add menu"
                             FontWeight="SemiBold" FontSize="14"
                             Foreground="{StaticResource Brush.Text}"/>
                  <TextBlock Text="Click the + icon on the right side of your playlist row."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="13" LineHeight="20" TextWrapping="Wrap"
                             Margin="0,5,0,0"/>
                </StackPanel>
              </Grid>

              <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource Brush.Blue}"
                        CornerRadius="16"
                        Width="33" Height="33"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                  <TextBlock Text="3" Foreground="White" FontFamily="{StaticResource Font.Display}" FontWeight="Bold" FontSize="15"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Add some music"
                             FontWeight="SemiBold" FontSize="14"
                             Foreground="{StaticResource Brush.Text}"/>
                  <TextBlock Text="Pick one of three ways:"
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="13" Margin="0,5,0,8"/>

                  <StackPanel Margin="2,0,0,0">
                    <TextBlock Foreground="{StaticResource Brush.TextDim}"
                               FontSize="13" LineHeight="20" TextWrapping="Wrap"
                               Margin="0,0,0,5">
                      <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" Text="Add files"/>
                      <Run Text=" — pick songs from your computer."/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Brush.TextDim}"
                               FontSize="13" LineHeight="20" TextWrapping="Wrap"
                               Margin="0,0,0,5">
                      <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" Text="Add folder"/>
                      <Run Text=" — import a whole folder at once."/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Brush.TextDim}"
                               FontSize="13" LineHeight="20" TextWrapping="Wrap">
                      <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" Text="Paste audio link"/>
                      <Run Text=" — paste a link from YouTube, Spotify, SoundCloud, and more."/>
                    </TextBlock>
                  </StackPanel>
                </StackPanel>
              </Grid>

              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource Brush.Blue}"
                        CornerRadius="16"
                        Width="33" Height="33"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                  <TextBlock Text="4" Foreground="White" FontFamily="{StaticResource Font.Display}" FontWeight="Bold" FontSize="15"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Press play"
                             FontWeight="SemiBold" FontSize="14"
                             Foreground="{StaticResource Brush.Text}"/>
                  <TextBlock Text="Double-click a song, or use the controls on the pill widget."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="13" LineHeight="20" TextWrapping="Wrap"
                             Margin="0,5,0,0"/>
                </StackPanel>
              </Grid>

            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

      <!-- ================== SHORTCUTS SUB-PAGE ================== -->
      <Grid x:Name="ShortcutsView" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0"
                  Style="{StaticResource IconGhostButton}"
                  ToolTip="Back"
                  Click="NavBack_Click">
            <Path Data="{StaticResource Icon.Back}"
                  Fill="{StaticResource Brush.Text}"
                  Stretch="Uniform"
                  Width="15" Height="15"/>
          </Button>
          <TextBlock Grid.Column="1"
                     Text="Shortcuts"
                     Style="{StaticResource PageTitle}"
                     Margin="8,0,0,0"/>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,20,22,20">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

              <TextBlock Text="Hotkeys &amp; gestures"
                         Foreground="{StaticResource Brush.Text}"
                         FontWeight="SemiBold"
                         FontSize="17"/>
              <TextBlock Text="Move and toggle the widget without lifting your hands."
                         Foreground="{StaticResource Brush.TextDim}"
                         FontSize="13"
                         Margin="0,3,0,18"/>

              <!--
                Each row is laid out as [keycap chips] | [description] so the
                chips align in a tidy column on the left. The chip column is
                fixed-width and the description wraps in the remaining space.
              -->

              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="185"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="Alt"/>
                  </Border>
                  <TextBlock Style="{StaticResource KbdPlus}"/>
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="\"/>
                  </Border>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Hide or show the widget."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="13" LineHeight="20" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="185"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="Ctrl"/>
                  </Border>
                  <TextBlock Style="{StaticResource KbdPlus}"/>
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="\"/>
                  </Border>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Open or close the dashboard."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="13" LineHeight="20" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="185"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Click outside"
                           Foreground="{StaticResource Brush.Text}"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="Closes the dashboard and leaves the player visible."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="13" LineHeight="20" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="185"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="Ctrl"/>
                  </Border>
                  <TextBlock Style="{StaticResource KbdPlus}"/>
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="Shift"/>
                  </Border>
                  <TextBlock Style="{StaticResource KbdPlus}"/>
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="\"/>
                  </Border>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Reset the widget position and dashboard size to defaults."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="13" LineHeight="20" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

              <!-- Gestures section -->
              <Border Background="{StaticResource Brush.Border}"
                      Height="1"
                      Margin="0,8,0,16"/>

              <TextBlock Text="Mouse gestures"
                         Foreground="{StaticResource Brush.Text}"
                         FontWeight="SemiBold"
                         FontSize="14"
                         Margin="0,0,0,10"/>

              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="185"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!--
                  Miniature replica of the pull-tab in HideToggleWindow.xaml:
                  a rounded-bottom pill in the same Bg.Pill color, with the
                  blue ChevronDown inside. Wrapped in a tooltip so users still
                  read "the chevron" if they hover.
                -->
                <Border Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{StaticResource Brush.Bg.Pill}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,5,5"
                        Width="26" Height="14"
                        SnapsToDevicePixels="True"
                        ToolTip="The pull-tab at the top of the screen">
                  <Path Data="{StaticResource Icon.ChevronDown}"
                        Fill="{StaticResource Brush.Blue}"
                        Stretch="Uniform"
                        Width="10" Height="5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="Same as Alt + \ — click to toggle the widget."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="13" LineHeight="20" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="185"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Style="{StaticResource KbdChip}"
                        HorizontalAlignment="Left">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource KbdText}"
                               Text="Drag"
                               Margin="0,0,5,0"/>
                    <UniformGrid Rows="3" Columns="2"
                                 Width="10" Height="14"
                                 VerticalAlignment="Center">
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </UniformGrid>
                  </StackPanel>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="Move the widget anywhere on screen."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="13" LineHeight="20" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

      <!-- ================== YOUTUBE COOKIES SUB-PAGE ================== -->
      <Grid x:Name="YoutubeCookiesView" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0"
                  Style="{StaticResource IconGhostButton}"
                  ToolTip="Back"
                  Click="NavBack_Click">
            <Path Data="{StaticResource Icon.Back}"
                  Fill="{StaticResource Brush.Text}"
                  Stretch="Uniform"
                  Width="15" Height="15"/>
          </Button>
          <TextBlock Grid.Column="1"
                     Text="Download cookies"
                     Style="{StaticResource PageTitle}"
                     Margin="8,0,0,0"/>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,20,22,20">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <TextBlock Text="When YouTube or Instagram asks you to sign in, export a cookies file and browse to it below."
                         Foreground="{StaticResource Brush.Text}"
                         FontWeight="SemiBold"
                         FontSize="17"
                         TextWrapping="Wrap"/>
              <TextBlock Text="Export a Netscape-format cookies.txt while logged into YouTube or Instagram (browser extension recommended; see yt-dlp wiki below). Beats passes it to yt-dlp and spotDL on every download."
                         Foreground="{StaticResource Brush.TextDim}"
                         FontSize="13"
                         Margin="0,8,0,16"
                         TextWrapping="Wrap"
                         LineHeight="20"/>

              <TextBlock Text="Cookies file"
                         Foreground="{StaticResource Brush.TextDim}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Margin="0,0,0,4"/>
              <TextBox x:Name="YoutubeCookiesPathBox"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       MinHeight="40"
                       Padding="9,7"
                       Margin="0,0,0,10"
                       Background="{StaticResource Brush.SurfaceHigh}"
                       BorderBrush="{StaticResource Brush.Border}"
                       Foreground="{StaticResource Brush.Text}"/>

              <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Style="{StaticResource PrimaryButton}"
                        Padding="12,6"
                        Margin="0,0,8,0"
                        Click="YoutubeCookiesBrowse_Click"
                        Content="Browse…"/>
                <Button Style="{StaticResource FlatButton}"
                        Padding="12,6"
                        Click="YoutubeCookiesClear_Click"
                        Content="Clear"/>
              </StackPanel>

              <TextBlock Foreground="{StaticResource Brush.TextDim}"
                         FontSize="13"
                         TextWrapping="Wrap"
                         LineHeight="20">
                <Run Text="Official guidance: "/>
                <Hyperlink NavigateUri="https://github.com/yt-dlp/yt-dlp/wiki/Extractors#exporting-youtube-cookies"
                           RequestNavigate="WikiLink_RequestNavigate">
                  Exporting YouTube cookies (yt-dlp wiki)
                </Hyperlink>
              </TextBlock>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

    </Grid>

  </Grid>
</UserControl>
