<UserControl x:Class="MusicWidget.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:MusicWidget.Models"
             xmlns:conv="clr-namespace:MusicWidget.Converters"
             x:Name="SettingsPanelRoot"
             Foreground="{StaticResource Brush.Text}"
             FontFamily="{StaticResource Font.Body}"
             FontSize="12"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
  <UserControl.Resources>
    <conv:ZoomMultiplyConverter x:Key="ZoomMultiply"/>
    <conv:ZoomThicknessConverter x:Key="ZoomThickness"/>

    <Style x:Key="PlaylistRowIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconGhostButton}">
      <Setter Property="Width" Value="22"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="PlaylistRowIconPathStyle" TargetType="Path">
      <Setter Property="Fill" Value="{StaticResource Brush.TextDim}"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
          <Setter Property="Fill" Value="White"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <DataTemplate DataType="{x:Type models:Track}">
      <Grid Background="Transparent"
            Margin="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomThickness}, ConverterParameter='0,1,0,1'}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0"
                Width="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=30}"
                Height="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=30}"
                CornerRadius="5"
                Background="{StaticResource Brush.SurfaceHigh}"
                ClipToBounds="True"
                Margin="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomThickness}, ConverterParameter='0,0,8,0'}">
          <Grid>
            <TextBlock Text="{Binding Initials}"
                       Foreground="{StaticResource Brush.TextDim}"
                       FontWeight="SemiBold"
                       FontSize="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=11}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <!--
              Painting the cover via ImageBrush on a Rectangle (instead of an Image
              control) guarantees center-cropped fill for any source aspect ratio.
              UniformToFill + AlignmentX/Y=Center is the reliable WPF idiom for
              square cover treatments; some sources (embedded ID3, iTunes lookups)
              return non-square artwork, and an <Image> can render off-center inside
              a rounded Border depending on layout slack.
            -->
            <Rectangle RenderOptions.BitmapScalingMode="HighQuality">
              <Rectangle.Style>
                <Style TargetType="Rectangle">
                  <Setter Property="Visibility" Value="Visible"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding ArtworkSource}" Value="{x:Null}">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Rectangle.Style>
              <Rectangle.Fill>
                <ImageBrush ImageSource="{Binding ArtworkSource}"
                            Stretch="UniformToFill"
                            AlignmentX="Center"
                            AlignmentY="Center"/>
              </Rectangle.Fill>
            </Rectangle>
          </Grid>
        </Border>
        <TextBlock Grid.Column="1"
                   Text="{Binding FriendlyDisplayName}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Margin="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomThickness}, ConverterParameter='0,0,6,0'}"/>
        <Path Grid.Column="2"
              Data="{StaticResource Icon.Heart}"
              Fill="#FFEF4444"
              Stretch="Uniform"
              VerticalAlignment="Center"
              Width="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=12}"
              Height="{Binding TracksZoom, ElementName=SettingsPanelRoot, Converter={StaticResource ZoomMultiply}, ConverterParameter=12}"
              Visibility="Collapsed">
          <Path.Style>
            <Style TargetType="Path">
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsLiked}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Path.Style>
        </Path>
      </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:Playlist}">
      <Grid Background="Transparent">
        <Grid.ContextMenu>
          <ContextMenu Opened="PlaylistContextMenu_Opened">
            <MenuItem Header="Play"
                      Click="PlaylistContextPlay_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Play}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="11" Height="11"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem x:Name="PlaylistMenuItemPin"
                      Header="Pin playlist"
                      Click="PlaylistContextPin_Click">
              <MenuItem.Icon>
                <Path x:Name="PlaylistMenuItemPinIcon"
                      Data="{StaticResource Icon.Pin}"
                      Fill="{StaticResource Brush.Blue}"
                      Stretch="Uniform"
                      Width="12" Height="12"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Add files…"
                      Click="PlaylistContextAddFiles_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Plus}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="11" Height="11"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Add folder…"
                      Click="PlaylistContextAddFolder_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Folder}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="12" Height="12"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Paste audio link…"
                      Click="PlaylistContextDownload_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Download}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="12" Height="12"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Open folder in File Explorer"
                      Click="PlaylistContextOpenFolder_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Folder}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="12" Height="12"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Rename…"
                      Click="PlaylistContextRename_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Edit}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="12" Height="12"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Delete playlist"
                      Click="PlaylistContextDelete_Click">
              <MenuItem.Icon>
                <Path Data="{StaticResource Icon.Trash}"
                      Fill="#FFEF4444"
                      Stretch="Uniform"
                      Width="12" Height="12"/>
              </MenuItem.Icon>
            </MenuItem>
          </ContextMenu>
        </Grid.ContextMenu>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0"
                Style="{StaticResource PlaylistRowIconButtonStyle}"
                Click="PlaylistPlayButton_Click"
                Tag="{Binding}"
                Margin="0,0,4,0">
          <Button.ToolTip>
            <ToolTip>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Play playlist from the start"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsPlayingNow}" Value="True">
                        <Setter Property="Text" Value="Pause"/>
                      </DataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding IsActivePlaylist}" Value="True"/>
                          <Condition Binding="{Binding IsPlayingNow}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Text" Value="Resume"/>
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </ToolTip>
          </Button.ToolTip>
          <Path Stretch="Uniform" Width="11" Height="11">
            <Path.Style>
              <Style TargetType="Path" BasedOn="{StaticResource PlaylistRowIconPathStyle}">
                <Setter Property="Data" Value="{StaticResource Icon.Play}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPlayingNow}" Value="True">
                    <Setter Property="Data" Value="{StaticResource Icon.Pause}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Path.Style>
          </Path>
        </Button>

        <!-- Pinned badge: heart for Liked, download for Saves, pin for user-pinned normals. -->
        <Path Grid.Column="1"
              x:Name="PinnedBadge"
              Stretch="Uniform"
              Width="12" Height="12"
              Margin="0,0,6,0"
              VerticalAlignment="Center"
              Visibility="Collapsed">
          <Path.Style>
            <Style TargetType="Path">
              <Setter Property="Fill" Value="{StaticResource Brush.Blue}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Liked">
                  <Setter Property="Fill" Value="#FFEF4444"/>
                  <Setter Property="Data" Value="{StaticResource Icon.Heart}"/>
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Saves">
                  <Setter Property="Fill" Value="{StaticResource Brush.Blue}"/>
                  <Setter Property="Data" Value="{StaticResource Icon.Download}"/>
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Kind}" Value="Normal"/>
                    <Condition Binding="{Binding IsPinned}" Value="True"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Fill" Value="{StaticResource Brush.Blue}"/>
                  <Setter Property="Data" Value="{StaticResource Icon.Pin}"/>
                  <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </Path.Style>
        </Path>

        <TextBlock Grid.Column="2"
                   Text="{Binding Name}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,4,0">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="FontWeight" Value="Normal"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                  <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>

        <!-- Rename / Delete / Add — shown for all real (Normal) playlists, even if
             the user has pinned them. Hidden only for virtual Liked/Saves. -->
        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Visible"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Liked">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Saves">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <Button Style="{StaticResource PlaylistRowIconButtonStyle}"
                  ToolTip="Rename playlist"
                  Click="PlaylistRenameButton_Click"
                  Tag="{Binding}">
            <Path Data="{StaticResource Icon.Edit}"
                  Style="{StaticResource PlaylistRowIconPathStyle}"
                  Stretch="Uniform"
                  Width="12" Height="12"/>
          </Button>
          <Button Style="{StaticResource PlaylistRowIconButtonStyle}"
                  ToolTip="Delete playlist"
                  Click="PlaylistDeleteButton_Click"
                  Tag="{Binding}">
            <Path Data="{StaticResource Icon.Trash}"
                  Style="{StaticResource PlaylistRowIconPathStyle}"
                  Stretch="Uniform"
                  Width="12" Height="12"/>
          </Button>
          <Button Style="{StaticResource PlaylistRowIconButtonStyle}"
                  ToolTip="Add music or download into this playlist"
                  Click="PlaylistAddButton_Click"
                  Tag="{Binding}">
            <Path Data="{StaticResource Icon.Plus}"
                  Style="{StaticResource PlaylistRowIconPathStyle}"
                  Stretch="Uniform"
                  Width="12" Height="12"/>
          </Button>
        </StackPanel>
      </Grid>
    </DataTemplate>

    <!-- Divider row between pinned and normal playlists -->
    <DataTemplate DataType="{x:Type models:PlaylistDivider}">
      <Grid Background="Transparent"
            Margin="0,4,0,4"
            IsHitTestVisible="False">
        <Border Height="1"
                Background="{StaticResource Brush.Border}"
                Opacity="0.65"
                Margin="2,0,2,0"/>
      </Grid>
    </DataTemplate>
  </UserControl.Resources>

  <Grid Margin="12,10,12,10">

    <!-- View container: only one of these is visible at a time -->
    <Grid x:Name="ViewContainer">

      <!-- ================== HOME VIEW ================== -->
      <Grid x:Name="HomeView" Visibility="Visible">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     Text="Dashboard"
                     Style="{StaticResource PageTitle}"
                     Margin="2,0,0,0"
                     VerticalAlignment="Center"/>
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        ToolTip="Keep the widget extended (loop and settings visible) at all times">
              <TextBlock Text="Extended widget"
                         FontSize="11"
                         Foreground="{StaticResource Brush.TextDim}"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0"/>
              <ToggleButton x:Name="KeepWidgetExpandedToggle"
                            Style="{StaticResource ToggleSwitch}"
                            VerticalAlignment="Center"
                            Click="KeepWidgetExpandedToggle_Click"/>
            </StackPanel>
            <Button x:Name="ResetLayoutButton"
                    Style="{StaticResource FlatButton}"
                    Padding="7,5"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    ToolTip="Reset layout: restore default widget position and dashboard size"
                    Click="ResetLayout_Click">
              <Path Data="{StaticResource Icon.Refresh}"
                    Fill="{StaticResource Brush.TextDim}"
                    Stretch="Uniform"
                    Width="13" Height="13"/>
            </Button>
            <Button x:Name="UpdateButton"
                    Style="{StaticResource FlatButton}"
                    Padding="9,5"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    ToolTip="Check for updates"
                    Click="UpdateButton_Click">
              <StackPanel Orientation="Horizontal">
                <Path x:Name="UpdateButtonIcon"
                      Data="{StaticResource Icon.Download}"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"
                      Margin="0,0,5,0"/>
                <TextBlock x:Name="UpdateButtonLabel"
                           Text="Update"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource FlatButton}"
                    Padding="9,5"
                    ToolTip="Open the help manual in your browser"
                    Click="OpenHelp_Click">
              <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource Icon.Info}"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      Margin="0,0,5,0"/>
                <TextBlock Text="Are you stuck?" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>

            <Button Style="{StaticResource FlatButton}"
                    Padding="9,5"
                    Margin="6,0,0,0"
                    ToolTip="Support the project"
                    Click="Donate_Click">
              <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource Icon.Heart}"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      Margin="0,0,5,0"/>
                <TextBlock Text="Donate" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>

            <Button Style="{StaticResource FlatButton}"
                    Padding="9,5"
                    Margin="6,0,0,0"
                    ToolTip="Minimize widget (use the top chevron or Ctrl+\\ to show again)"
                    Click="MinimizeWidget_Click">
              <Path Data="{StaticResource Icon.Minimize}"
                    Stretch="Uniform"
                    Width="12" Height="12"
                    Stroke="{StaticResource Brush.TextDim}"
                    StrokeThickness="2"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"/>
            </Button>

            <Button Style="{StaticResource DangerButton}"
                    Padding="9,5"
                    Margin="6,0,0,0"
                    ToolTip="Close Beats"
                    Click="ExitApp_Click">
              <Path Data="{StaticResource Icon.Close}"
                    Fill="White"
                    Stretch="Uniform"
                    Width="12" Height="12"/>
            </Button>
          </StackPanel>
        </Grid>

        <Border x:Name="BackgroundDownloadBanner"
                Grid.Row="1"
                Visibility="Collapsed"
                Margin="0,0,0,10"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock x:Name="BackgroundDownloadTitle"
                         Text="Downloading in background"
                         FontWeight="SemiBold"
                         FontSize="11"
                         Foreground="{StaticResource Brush.Text}"/>
              <TextBlock x:Name="BackgroundDownloadDetail"
                         FontSize="10"
                         Foreground="{StaticResource Brush.TextDim}"
                         Margin="0,2,0,6"
                         TextTrimming="CharacterEllipsis"/>
              <ProgressBar x:Name="BackgroundDownloadProgress"
                           Height="4"
                           Minimum="0"
                           Maximum="100"
                           Foreground="{StaticResource Brush.Blue}"
                           Background="{StaticResource Brush.SurfaceHigh}"
                           BorderThickness="0"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
              <TextBlock x:Name="BackgroundDownloadPercent"
                         HorizontalAlignment="Right"
                         FontSize="10.5"
                         Foreground="{StaticResource Brush.TextDim}"/>
              <Button x:Name="BackgroundDownloadCancelButton"
                      Style="{StaticResource FlatButton}"
                      Content="Cancel"
                      Padding="8,3"
                      Margin="0,6,0,0"
                      FontSize="10"
                      HorizontalAlignment="Right"
                      ToolTip="Stop this download"
                      Click="BackgroundDownloadCancel_Click"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Playlists + Songs section -->
        <Border Grid.Row="2"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="9">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" x:Name="PlaylistsSongsGrid">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="120"/>
              </Grid.ColumnDefinitions>

              <Grid Grid.Column="0" Margin="0,0,4,0">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             Text="Playlists"
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="10"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center"/>
                  <Button Grid.Column="1"
                          Style="{StaticResource PrimaryButton}"
                          Padding="8,3"
                          FontSize="11"
                          Click="NewPlaylist_Click"
                          ToolTip="Create a new playlist">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Path Data="{StaticResource Icon.Plus}"
                            Fill="White"
                            Stretch="Uniform"
                            Width="9" Height="9"
                            Margin="0,0,4,0"/>
                      <TextBlock Text="New Playlist" FontWeight="SemiBold"/>
                    </StackPanel>
                  </Button>
                </Grid>
                <ListBox Grid.Row="1"
                         x:Name="PlaylistsList"
                         Style="{StaticResource DarkListBox}"
                         SelectionChanged="PlaylistsList_SelectionChanged"/>
              </Grid>

              <GridSplitter Grid.Column="1"
                            Style="{StaticResource SectionSplitter}"/>

              <Grid Grid.Column="2" Margin="4,0,0,0">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             x:Name="TracksHeader"
                             Text="Songs"
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="10"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"/>
                  <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              VerticalAlignment="Center">
                    <Button x:Name="PlayPauseTrackButton"
                            Style="{StaticResource PrimaryButton}"
                            Padding="8,3"
                            FontSize="11"
                            Click="PlayTrack_Click">
                      <Button.ToolTip>
                        <ToolTip>
                          <TextBlock x:Name="PlayPauseTrackTooltip" Text="Play"/>
                        </ToolTip>
                      </Button.ToolTip>
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path x:Name="PlayPauseTrackIcon"
                              Data="{StaticResource Icon.Play}"
                              Fill="White"
                              Stretch="Uniform"
                              Width="9" Height="9"
                              Margin="0,0,4,0"/>
                        <TextBlock x:Name="PlayPauseTrackLabel"
                                   Text="Play"
                                   FontWeight="SemiBold"/>
                      </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PlaylistRowIconButtonStyle}"
                            Margin="5,0,0,0"
                            ToolTip="Add music or download into this playlist"
                            Click="SongsAddButton_Click">
                      <Path Data="{StaticResource Icon.Plus}"
                            Fill="{StaticResource Brush.TextDim}"
                            Stretch="Uniform"
                            Width="12" Height="12"/>
                    </Button>
                  </StackPanel>
                </Grid>
                <ListBox Grid.Row="1"
                         x:Name="TracksList"
                         Style="{StaticResource DarkListBox}"
                         AllowDrop="True"
                         ToolTip="Drag songs to reorder. Ctrl + scroll wheel to resize song rows."
                         PreviewMouseLeftButtonDown="TracksList_PreviewMouseLeftButtonDown"
                         PreviewMouseLeftButtonUp="TracksList_PreviewMouseLeftButtonUp"
                         PreviewMouseMove="TracksList_PreviewMouseMove"
                         DragOver="TracksList_DragOver"
                         Drop="TracksList_Drop"
                         PreviewMouseWheel="TracksList_PreviewMouseWheel"
                         MouseDoubleClick="TracksList_MouseDoubleClick"
                         PreviewMouseRightButtonDown="TracksList_PreviewMouseRightButtonDown">
                  <ListBox.ContextMenu>
                    <ContextMenu x:Name="TrackContextMenu"
                                 Opened="TrackContextMenu_Opened">
                      <MenuItem Header="Play"
                                Click="TrackContextPlay_Click">
                        <MenuItem.Icon>
                          <Path Data="{StaticResource Icon.Play}"
                                Fill="{StaticResource Brush.Text}"
                                Stretch="Uniform"
                                Width="11" Height="11"/>
                        </MenuItem.Icon>
                      </MenuItem>
                      <Separator/>
                      <MenuItem x:Name="MenuItemLike"
                                Header="Add to Liked Songs"
                                Click="TrackContextLike_Click">
                        <MenuItem.Icon>
                          <Path x:Name="MenuItemLikeIcon"
                                Data="{StaticResource Icon.Heart}"
                                Fill="#FFEF4444"
                                Stretch="Uniform"
                                Width="12" Height="12"/>
                        </MenuItem.Icon>
                      </MenuItem>
                      <Separator/>
                      <MenuItem Header="Show in File Explorer"
                                Click="TrackContextShowInExplorer_Click">
                        <MenuItem.Icon>
                          <Path Data="{StaticResource Icon.Folder}"
                                Fill="{StaticResource Brush.Text}"
                                Stretch="Uniform"
                                Width="12" Height="12"/>
                        </MenuItem.Icon>
                      </MenuItem>
                      <MenuItem Header="Copy file path"
                                Click="TrackContextCopyPath_Click">
                        <MenuItem.Icon>
                          <Path Data="{StaticResource Icon.Link}"
                                Fill="{StaticResource Brush.Text}"
                                Stretch="Uniform"
                                Width="12" Height="12"/>
                        </MenuItem.Icon>
                      </MenuItem>
                      <Separator x:Name="SeparatorBeforeEdit"/>
                      <MenuItem x:Name="MenuItemEdit"
                                Header="Edit..."
                                Click="TrackContextEdit_Click">
                        <MenuItem.Icon>
                          <Path Data="{StaticResource Icon.Edit}"
                                Fill="{StaticResource Brush.Text}"
                                Stretch="Uniform"
                                Width="12" Height="12"/>
                        </MenuItem.Icon>
                      </MenuItem>
                      <MenuItem x:Name="MenuItemDelete"
                                Header="Delete from playlist"
                                Click="TrackContextDelete_Click">
                        <MenuItem.Icon>
                          <Path x:Name="MenuItemDeleteIcon"
                                Data="{StaticResource Icon.Trash}"
                                Fill="#FFEF4444"
                                Stretch="Uniform"
                                Width="12" Height="12"/>
                        </MenuItem.Icon>
                      </MenuItem>
                    </ContextMenu>
                  </ListBox.ContextMenu>
                </ListBox>
              </Grid>
            </Grid>
          </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- Now Playing footer (cover, title/artist, transport, volume)   -->
        <!-- ============================================================ -->
        <Border Grid.Row="3"
                Margin="0,10,0,0"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="160"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*" MinWidth="160"/>
            </Grid.ColumnDefinitions>

            <!-- Left: cover + title/artist + like + save -->
            <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MaxWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0"
                      Width="44" Height="44"
                      CornerRadius="6"
                      Background="{StaticResource Brush.SurfaceHigh}"
                      ClipToBounds="True">
                <Grid>
                  <TextBlock x:Name="NowPlayingInitials"
                             Text=""
                             Foreground="{StaticResource Brush.TextDim}"
                             FontFamily="{StaticResource Font.Display}"
                             FontWeight="SemiBold"
                             FontSize="14"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                  <!-- Rectangle + ImageBrush: see Track DataTemplate above for the
                       rationale. Guarantees a center-cropped cover no matter the
                       source aspect ratio. -->
                  <Rectangle x:Name="NowPlayingArt"
                             Visibility="Collapsed"
                             RenderOptions.BitmapScalingMode="HighQuality">
                    <Rectangle.Fill>
                      <ImageBrush x:Name="NowPlayingArtBrush"
                                  Stretch="UniformToFill"
                                  AlignmentX="Center"
                                  AlignmentY="Center"/>
                    </Rectangle.Fill>
                  </Rectangle>
                </Grid>
              </Border>
              <StackPanel Grid.Column="1"
                          Margin="10,0,0,0"
                          VerticalAlignment="Center">
                <TextBlock x:Name="NowPlayingTitle"
                           Text="Nothing playing"
                           Foreground="{StaticResource Brush.Text}"
                           FontFamily="{StaticResource Font.Body}"
                           FontWeight="SemiBold"
                           FontSize="12.5"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="NowPlayingArtist"
                           Text=""
                           Foreground="{StaticResource Brush.TextDim}"
                           FontFamily="{StaticResource Font.Body}"
                           FontSize="11"
                           Margin="0,2,0,0"
                           TextTrimming="CharacterEllipsis"/>
              </StackPanel>

              <!-- Like / Save toggles for the current track. -->
              <Button Grid.Column="2"
                      x:Name="FooterLikeButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="28" Height="28"
                      Margin="8,0,0,0"
                      Click="FooterLike_Click">
                <Button.ToolTip>
                  <ToolTip>
                    <TextBlock x:Name="FooterLikeTooltip" Text="Add to Liked Songs"/>
                  </ToolTip>
                </Button.ToolTip>
                <Path x:Name="FooterLikeIcon"
                      Data="{StaticResource Icon.Heart}"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="13" Height="13"/>
              </Button>
              <Button Grid.Column="3"
                      x:Name="FooterSaveButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="28" Height="28"
                      Margin="3,0,0,0"
                      Click="FooterSave_Click">
                <Button.ToolTip>
                  <ToolTip>
                    <TextBlock x:Name="FooterSaveTooltip" Text="Add to Saves"/>
                  </ToolTip>
                </Button.ToolTip>
                <Path x:Name="FooterSaveIcon"
                      Data="{StaticResource Icon.Download}"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="13" Height="13"/>
              </Button>
            </Grid>

            <!-- Center: shuffle / previous / play-pause / next / loop -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
              <Button x:Name="ShuffleButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="30" Height="30"
                      Margin="0,0,4,0"
                      ToolTip="Shuffle"
                      Click="ShuffleButton_Click">
                <Path x:Name="ShuffleIcon"
                      Data="{StaticResource Icon.Shuffle}"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="14" Height="14"/>
              </Button>
              <Button x:Name="FooterPrevButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="30" Height="30"
                      ToolTip="Previous"
                      Click="FooterPrev_Click">
                <Path Data="{StaticResource Icon.Previous}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="14" Height="14"/>
              </Button>
              <Button x:Name="FooterPlayPauseButton"
                      Style="{StaticResource BlueCircleButton}"
                      Width="38" Height="38"
                      Margin="8,0"
                      Click="FooterPlayPause_Click">
                <Button.ToolTip>
                  <ToolTip>
                    <TextBlock x:Name="FooterPlayPauseTooltip" Text="Play"/>
                  </ToolTip>
                </Button.ToolTip>
                <Path x:Name="FooterPlayPauseIcon"
                      Data="{StaticResource Icon.Play}"
                      Fill="White"
                      Stretch="Uniform"
                      Width="14" Height="14"/>
              </Button>
              <Button x:Name="FooterNextButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="30" Height="30"
                      ToolTip="Next"
                      Click="FooterNext_Click">
                <Path Data="{StaticResource Icon.Next}"
                      Fill="{StaticResource Brush.Text}"
                      Stretch="Uniform"
                      Width="14" Height="14"/>
              </Button>
              <Button x:Name="FooterLoopButton"
                      Style="{StaticResource PlaylistRowIconButtonStyle}"
                      Width="30" Height="30"
                      Margin="4,0,0,0"
                      Click="FooterLoop_Click">
                <Button.ToolTip>
                  <ToolTip>
                    <TextBlock x:Name="FooterLoopTooltip" Text="Loop: OFF"/>
                  </ToolTip>
                </Button.ToolTip>
                <Grid Width="14" Height="14">
                  <Rectangle x:Name="FooterLoopIconRect">
                    <Rectangle.Fill>
                      <SolidColorBrush Color="#94A3B8"/>
                    </Rectangle.Fill>
                    <Rectangle.OpacityMask>
                      <ImageBrush ImageSource="pack://application:,,,/Assets/loop.png"
                                  Stretch="Uniform"/>
                    </Rectangle.OpacityMask>
                  </Rectangle>
                </Grid>
              </Button>
            </StackPanel>

            <!-- Right: volume + progress -->
            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        MinWidth="200">
              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Right">
                <Button x:Name="FooterMuteButton"
                        Style="{StaticResource PlaylistRowIconButtonStyle}"
                        Width="26" Height="26"
                        Margin="0,0,6,0"
                        Click="FooterMute_Click"
                        ToolTip="Mute / unmute">
                  <Path x:Name="FooterVolumeIcon"
                        Data="{StaticResource Icon.Volume}"
                        Fill="{StaticResource Brush.TextDim}"
                        Stretch="Uniform"
                        Width="14" Height="14"/>
                </Button>
                <Slider x:Name="FooterVolumeSlider"
                        Width="110"
                        Minimum="0"
                        Maximum="100"
                        SmallChange="1"
                        LargeChange="10"
                        Value="80"
                        VerticalAlignment="Center"
                        IsMoveToPointEnabled="True"
                        ValueChanged="FooterVolume_ValueChanged"
                        ToolTip="Volume"/>
              </StackPanel>
              <Grid Margin="0,8,0,0"
                    HorizontalAlignment="Stretch"
                    MinWidth="200"
                    Width="220">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterPositionLabel"
                           Grid.Column="0"
                           Text="0:00"
                           Foreground="{StaticResource Brush.TextDim}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="10.5"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Slider x:Name="FooterProgressSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="1"
                        Value="0"
                        VerticalAlignment="Center"
                        IsMoveToPointEnabled="True"
                        ValueChanged="FooterProgress_ValueChanged"
                        ToolTip="Seek"/>
                <TextBlock x:Name="FooterDurationLabel"
                           Grid.Column="2"
                           Text="0:00"
                           Foreground="{StaticResource Brush.TextDim}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="10.5"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
              </Grid>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <!-- ================== HELP HUB ================== -->
      <Grid x:Name="HelpView" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0"
                  Style="{StaticResource IconGhostButton}"
                  ToolTip="Back"
                  Click="NavBack_Click">
            <Path Data="{StaticResource Icon.Back}"
                  Fill="{StaticResource Brush.Text}"
                  Stretch="Uniform"
                  Width="15" Height="15"/>
          </Button>
          <TextBlock Grid.Column="1"
                     Text="Are you stuck?"
                     Style="{StaticResource PageTitle}"
                     Margin="8,0,0,0"/>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20">
          <StackPanel>
            <TextBlock Text="How can we help?"
                       Foreground="{StaticResource Brush.Text}"
                       FontWeight="SemiBold"
                       FontSize="15"/>
            <TextBlock Text="Pick a section to learn more about the widget."
                       Foreground="{StaticResource Brush.TextDim}"
                       FontSize="12"
                       Margin="0,3,0,18"/>

            <Button Style="{StaticResource NavCardButton}"
                    Margin="0,0,0,10"
                    ToolTip="Get music playing in four steps"
                    Click="OpenQuickStart_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{StaticResource Brush.Blue}"
                        CornerRadius="10"
                        Width="36" Height="36"
                        Margin="0,0,12,0">
                  <Path Data="{StaticResource Icon.Play}"
                        Fill="White"
                        Stretch="Uniform"
                        Width="16" Height="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Quick start"
                             Foreground="{StaticResource Brush.Text}"
                             FontWeight="SemiBold"
                             FontSize="13"/>
                  <TextBlock Text="Create a playlist and start listening."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="11"
                             Margin="0,2,0,0"/>
                </StackPanel>
                <Path Grid.Column="2"
                      Data="M 8.59,16.59 L 13.17,12 L 8.59,7.41 L 10,6 L 16,12 L 10,18 z"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Style="{StaticResource NavCardButton}"
                    Margin="0,0,0,10"
                    ToolTip="YouTube cookie file for yt-dlp when browser import fails"
                    Click="OpenYoutubeCookies_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{StaticResource Brush.Blue}"
                        CornerRadius="10"
                        Width="36" Height="36"
                        Margin="0,0,12,0">
                  <Path Data="{StaticResource Icon.Link}"
                        Fill="White"
                        Stretch="Uniform"
                        Width="14" Height="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Download cookies"
                             Foreground="{StaticResource Brush.Text}"
                             FontWeight="SemiBold"
                             FontSize="13"/>
                  <TextBlock Text="Optional cookies.txt for YouTube, Instagram, and blocked links."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="11"
                             Margin="0,2,0,0"/>
                </StackPanel>
                <Path Grid.Column="2"
                      Data="M 8.59,16.59 L 13.17,12 L 8.59,7.41 L 10,6 L 16,12 L 10,18 z"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Style="{StaticResource NavCardButton}"
                    Margin="0,0,0,10"
                    ToolTip="Keyboard and mouse shortcuts"
                    Click="OpenShortcuts_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{StaticResource Brush.Blue}"
                        CornerRadius="10"
                        Width="36" Height="36"
                        Margin="0,0,12,0">
                  <Path Data="{StaticResource Icon.Bolt}"
                        Fill="White"
                        Stretch="Uniform"
                        Width="14" Height="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Shortcuts"
                             Foreground="{StaticResource Brush.Text}"
                             FontWeight="SemiBold"
                             FontSize="13"/>
                  <TextBlock Text="Hotkeys and quick gestures."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="11"
                             Margin="0,2,0,0"/>
                </StackPanel>
                <Path Grid.Column="2"
                      Data="M 8.59,16.59 L 13.17,12 L 8.59,7.41 L 10,6 L 16,12 L 10,18 z"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Style="{StaticResource NavCardButton}"
                    ToolTip="Open delexo.store in your browser"
                    Click="OpenMorePrograms_Click">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{StaticResource Brush.Blue}"
                        CornerRadius="10"
                        Width="36" Height="36"
                        Margin="0,0,12,0">
                  <Path Data="{StaticResource Icon.Apps}"
                        Fill="White"
                        Stretch="Uniform"
                        Width="15" Height="15"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="More Programs"
                             Foreground="{StaticResource Brush.Text}"
                             FontWeight="SemiBold"
                             FontSize="13"/>
                  <TextBlock Text="Browse other tools at delexo.store."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="11"
                             Margin="0,2,0,0"/>
                </StackPanel>
                <Path Grid.Column="2"
                      Data="M 14,3 V 5 H 17.59 L 7.76,14.83 L 9.17,16.24 L 19,6.41 V 10 H 21 V 3 z M 19,19 H 5 V 5 H 12 V 3 H 5 c -1.11,0 -2,0.9 -2,2 V 19 a 2,2 0 0 0 2,2 H 19 a 2,2 0 0 0 2,-2 V 12 H 19 V 19 z"
                      Fill="{StaticResource Brush.TextDim}"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"/>
              </Grid>
            </Button>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ================== QUICK START SUB-PAGE ================== -->
      <Grid x:Name="QuickStartView" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0"
                  Style="{StaticResource IconGhostButton}"
                  ToolTip="Back"
                  Click="NavBack_Click">
            <Path Data="{StaticResource Icon.Back}"
                  Fill="{StaticResource Brush.Text}"
                  Stretch="Uniform"
                  Width="15" Height="15"/>
          </Button>
          <TextBlock Grid.Column="1"
                     Text="Quick start"
                     Style="{StaticResource PageTitle}"
                     Margin="8,0,0,0"/>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,20,22,20">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

              <TextBlock Text="Get music playing"
                         Foreground="{StaticResource Brush.Text}"
                         FontWeight="SemiBold"
                         FontSize="15"/>
              <TextBlock Text="Four simple steps."
                         Foreground="{StaticResource Brush.TextDim}"
                         FontSize="12"
                         Margin="0,3,0,22"/>

              <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource Brush.Blue}"
                        CornerRadius="16"
                        Width="30" Height="30"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                  <TextBlock Text="1" Foreground="White" FontFamily="{StaticResource Font.Display}" FontWeight="Bold" FontSize="14"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Create a playlist"
                             FontWeight="SemiBold" FontSize="13"
                             Foreground="{StaticResource Brush.Text}"/>
                  <TextBlock Text="Click &#x201C;New Playlist&#x201D; at the top of the list and give it a name."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="12" LineHeight="18" TextWrapping="Wrap"
                             Margin="0,5,0,0"/>
                </StackPanel>
              </Grid>

              <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource Brush.Blue}"
                        CornerRadius="16"
                        Width="30" Height="30"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                  <TextBlock Text="2" Foreground="White" FontFamily="{StaticResource Font.Display}" FontWeight="Bold" FontSize="14"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Open the add menu"
                             FontWeight="SemiBold" FontSize="13"
                             Foreground="{StaticResource Brush.Text}"/>
                  <TextBlock Text="Click the + icon on the right side of your playlist row."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="12" LineHeight="18" TextWrapping="Wrap"
                             Margin="0,5,0,0"/>
                </StackPanel>
              </Grid>

              <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource Brush.Blue}"
                        CornerRadius="16"
                        Width="30" Height="30"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                  <TextBlock Text="3" Foreground="White" FontFamily="{StaticResource Font.Display}" FontWeight="Bold" FontSize="14"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Add some music"
                             FontWeight="SemiBold" FontSize="13"
                             Foreground="{StaticResource Brush.Text}"/>
                  <TextBlock Text="Pick one of three ways:"
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="12" Margin="0,5,0,8"/>

                  <StackPanel Margin="2,0,0,0">
                    <TextBlock Foreground="{StaticResource Brush.TextDim}"
                               FontSize="12" LineHeight="18" TextWrapping="Wrap"
                               Margin="0,0,0,5">
                      <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" Text="Add files"/>
                      <Run Text=" — pick songs from your computer."/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Brush.TextDim}"
                               FontSize="12" LineHeight="18" TextWrapping="Wrap"
                               Margin="0,0,0,5">
                      <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" Text="Add folder"/>
                      <Run Text=" — import a whole folder at once."/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Brush.TextDim}"
                               FontSize="12" LineHeight="18" TextWrapping="Wrap">
                      <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" Text="Paste audio link"/>
                      <Run Text=" — paste a link from YouTube, Spotify, SoundCloud, and more."/>
                    </TextBlock>
                  </StackPanel>
                </StackPanel>
              </Grid>

              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource Brush.Blue}"
                        CornerRadius="16"
                        Width="30" Height="30"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                  <TextBlock Text="4" Foreground="White" FontFamily="{StaticResource Font.Display}" FontWeight="Bold" FontSize="14"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="Press play"
                             FontWeight="SemiBold" FontSize="13"
                             Foreground="{StaticResource Brush.Text}"/>
                  <TextBlock Text="Double-click a song, or use the controls on the pill widget."
                             Foreground="{StaticResource Brush.TextDim}"
                             FontSize="12" LineHeight="18" TextWrapping="Wrap"
                             Margin="0,5,0,0"/>
                </StackPanel>
              </Grid>

            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

      <!-- ================== SHORTCUTS SUB-PAGE ================== -->
      <Grid x:Name="ShortcutsView" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0"
                  Style="{StaticResource IconGhostButton}"
                  ToolTip="Back"
                  Click="NavBack_Click">
            <Path Data="{StaticResource Icon.Back}"
                  Fill="{StaticResource Brush.Text}"
                  Stretch="Uniform"
                  Width="15" Height="15"/>
          </Button>
          <TextBlock Grid.Column="1"
                     Text="Shortcuts"
                     Style="{StaticResource PageTitle}"
                     Margin="8,0,0,0"/>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,20,22,20">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

              <TextBlock Text="Hotkeys &amp; gestures"
                         Foreground="{StaticResource Brush.Text}"
                         FontWeight="SemiBold"
                         FontSize="15"/>
              <TextBlock Text="Move and toggle the widget without lifting your hands."
                         Foreground="{StaticResource Brush.TextDim}"
                         FontSize="12"
                         Margin="0,3,0,18"/>

              <!--
                Each row is laid out as [keycap chips] | [description] so the
                chips align in a tidy column on the left. The chip column is
                fixed-width and the description wraps in the remaining space.
              -->

              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="170"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="Alt"/>
                  </Border>
                  <TextBlock Style="{StaticResource KbdPlus}"/>
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="\"/>
                  </Border>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Hide or show the widget."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="12" LineHeight="18" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="170"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="Ctrl"/>
                  </Border>
                  <TextBlock Style="{StaticResource KbdPlus}"/>
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="\"/>
                  </Border>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Open or close the dashboard."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="12" LineHeight="18" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="170"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="Ctrl"/>
                  </Border>
                  <TextBlock Style="{StaticResource KbdPlus}"/>
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="Shift"/>
                  </Border>
                  <TextBlock Style="{StaticResource KbdPlus}"/>
                  <Border Style="{StaticResource KbdChip}">
                    <TextBlock Style="{StaticResource KbdText}" Text="\"/>
                  </Border>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Reset the widget position and dashboard size to defaults."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="12" LineHeight="18" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

              <!-- Gestures section -->
              <Border Background="{StaticResource Brush.Border}"
                      Height="1"
                      Margin="0,8,0,16"/>

              <TextBlock Text="Mouse gestures"
                         Foreground="{StaticResource Brush.Text}"
                         FontWeight="SemiBold"
                         FontSize="13"
                         Margin="0,0,0,10"/>

              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="170"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!--
                  Miniature replica of the pull-tab in HideToggleWindow.xaml:
                  a rounded-bottom pill in the same Bg.Pill color, with the
                  blue ChevronDown inside. Wrapped in a tooltip so users still
                  read "the chevron" if they hover.
                -->
                <Border Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{StaticResource Brush.Bg.Pill}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,5,5"
                        Width="26" Height="14"
                        SnapsToDevicePixels="True"
                        ToolTip="The pull-tab at the top of the screen">
                  <Path Data="{StaticResource Icon.ChevronDown}"
                        Fill="{StaticResource Brush.Blue}"
                        Stretch="Uniform"
                        Width="10" Height="5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="Same as Alt + \ — click to toggle the widget."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="12" LineHeight="18" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="170"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Style="{StaticResource KbdChip}"
                        HorizontalAlignment="Left">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource KbdText}"
                               Text="Drag"
                               Margin="0,0,5,0"/>
                    <UniformGrid Rows="3" Columns="2"
                                 Width="10" Height="14"
                                 VerticalAlignment="Center">
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      <Ellipse Width="3" Height="3"
                               Fill="{StaticResource Brush.Text}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </UniformGrid>
                  </StackPanel>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="Move the widget anywhere on screen."
                           Foreground="{StaticResource Brush.TextDim}"
                           FontSize="12" LineHeight="18" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
              </Grid>

            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

      <!-- ================== YOUTUBE COOKIES SUB-PAGE ================== -->
      <Grid x:Name="YoutubeCookiesView" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0"
                  Style="{StaticResource IconGhostButton}"
                  ToolTip="Back"
                  Click="NavBack_Click">
            <Path Data="{StaticResource Icon.Back}"
                  Fill="{StaticResource Brush.Text}"
                  Stretch="Uniform"
                  Width="15" Height="15"/>
          </Button>
          <TextBlock Grid.Column="1"
                     Text="Download cookies"
                     Style="{StaticResource PageTitle}"
                     Margin="8,0,0,0"/>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,20,22,20">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <TextBlock Text="When YouTube or Instagram asks you to sign in, export a cookies file and browse to it below."
                         Foreground="{StaticResource Brush.Text}"
                         FontWeight="SemiBold"
                         FontSize="15"
                         TextWrapping="Wrap"/>
              <TextBlock Text="Export a Netscape-format cookies.txt while logged into YouTube or Instagram (browser extension recommended; see yt-dlp wiki below). Beats passes it to yt-dlp and spotDL on every download."
                         Foreground="{StaticResource Brush.TextDim}"
                         FontSize="12"
                         Margin="0,8,0,16"
                         TextWrapping="Wrap"
                         LineHeight="18"/>

              <TextBlock Text="Cookies file"
                         Foreground="{StaticResource Brush.TextDim}"
                         FontSize="10"
                         FontWeight="SemiBold"
                         Margin="0,0,0,4"/>
              <TextBox x:Name="YoutubeCookiesPathBox"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       MinHeight="36"
                       Padding="8,6"
                       Margin="0,0,0,10"
                       Background="{StaticResource Brush.SurfaceHigh}"
                       BorderBrush="{StaticResource Brush.Border}"
                       Foreground="{StaticResource Brush.Text}"/>

              <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Style="{StaticResource PrimaryButton}"
                        Padding="12,6"
                        Margin="0,0,8,0"
                        Click="YoutubeCookiesBrowse_Click"
                        Content="Browse…"/>
                <Button Style="{StaticResource FlatButton}"
                        Padding="12,6"
                        Click="YoutubeCookiesClear_Click"
                        Content="Clear"/>
              </StackPanel>

              <TextBlock Foreground="{StaticResource Brush.TextDim}"
                         FontSize="12"
                         TextWrapping="Wrap"
                         LineHeight="18">
                <Run Text="Official guidance: "/>
                <Hyperlink NavigateUri="https://github.com/yt-dlp/yt-dlp/wiki/Extractors#exporting-youtube-cookies"
                           RequestNavigate="WikiLink_RequestNavigate">
                  Exporting YouTube cookies (yt-dlp wiki)
                </Hyperlink>
              </TextBlock>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

    </Grid>

  </Grid>
</UserControl>
