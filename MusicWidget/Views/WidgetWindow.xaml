<Window x:Class="MusicWidget.Views.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MusicWidget.Views"
        Title="Beats"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        FontFamily="{StaticResource Font.Body}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

  <Grid x:Name="RootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Pill bar -->
    <Border x:Name="PillBorder"
            Grid.Row="0"
            Style="{StaticResource PillBar}"
            HorizontalAlignment="Center">
      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center">

        <Button x:Name="GearButton"
                Style="{StaticResource BlueCircleButton}"
                ToolTip="Dashboard"
                Click="Gear_Click">
          <Path Data="{StaticResource Icon.Gear}"
                Fill="White"
                Stretch="Uniform"
                Width="15" Height="15"/>
        </Button>

        <Button x:Name="LoopButton"
                Style="{StaticResource BlueCircleButton}"
                Margin="6,0,0,0"
                ToolTip="Loop current song"
                Click="Loop_Click">
          <Grid Width="17" Height="17">
            <Path x:Name="LoopIcon"
                  Style="{StaticResource LoopStrokeIconStyle}"
                  Stroke="White"/>
            <Path x:Name="LoopOneMark"
                  Style="{StaticResource LoopOneMarkStyle}"
                  Fill="White"/>
          </Grid>
        </Button>

        <Grid Width="22" Height="28"
              Margin="8,0"
              VerticalAlignment="Center">
          <UniformGrid Rows="3" Columns="2"
                       Width="14" Height="20"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       IsHitTestVisible="False">
            <UniformGrid.Resources>
              <Style TargetType="Ellipse">
                <Setter Property="Width" Value="4"/>
                <Setter Property="Height" Value="4"/>
                <Setter Property="Fill" Value="White"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
              </Style>
            </UniformGrid.Resources>
            <Ellipse/>
            <Ellipse/>
            <Ellipse/>
            <Ellipse/>
            <Ellipse/>
            <Ellipse/>
          </UniformGrid>
          <Thumb Style="{StaticResource MoveThumbStyle}"
                 DragStarted="MoveThumb_DragStarted"
                 DragDelta="MoveThumb_DragDelta"
                 DragCompleted="MoveThumb_DragCompleted"/>
        </Grid>

        <Button x:Name="PrevButton"
                Style="{StaticResource BlueCircleButton}"
                ToolTip="Previous"
                Click="Prev_Click">
          <Path Data="{StaticResource Icon.Previous}"
                Fill="White"
                Stretch="Uniform"
                Width="15" Height="15"/>
        </Button>

        <Button x:Name="PlayPauseButton"
                Style="{StaticResource BlueCircleButton}"
                Margin="6,0,0,0"
                ToolTip="Play / Pause"
                Click="PlayPause_Click">
          <Path x:Name="PlayPauseIcon"
                Data="{StaticResource Icon.Play}"
                Fill="White"
                Stretch="Uniform"
                Width="14" Height="14"/>
        </Button>

        <Button x:Name="NextButton"
                Style="{StaticResource BlueCircleButton}"
                Margin="6,0,0,0"
                ToolTip="Next"
                Click="Next_Click">
          <Path Data="{StaticResource Icon.Next}"
                Fill="White"
                Stretch="Uniform"
                Width="15" Height="15"/>
        </Button>

      </StackPanel>
    </Border>

    <!-- Now playing label -->
    <TextBlock x:Name="NowPlayingLabel"
               Grid.Row="1"
               HorizontalAlignment="Center"
               Margin="0,6,0,0"
               Foreground="White"
               FontFamily="{StaticResource Font.Accent}"
               FontSize="11"
               FontStyle="Italic"
               FontWeight="SemiBold"
               TextTrimming="CharacterEllipsis"
               MaxWidth="320"
               Opacity="0"
               IsHitTestVisible="False"
               Text=""/>

    <!-- Settings panel host (animated expand) -->
    <Border x:Name="SettingsHost"
            Grid.Row="2"
            Margin="0,6,0,0"
            HorizontalAlignment="Stretch"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="14"
            Height="0"
            Visibility="Collapsed"
            ClipToBounds="True">
      <Border.Effect>
        <DropShadowEffect Color="Black" Opacity="0.55" BlurRadius="20" ShadowDepth="5"/>
      </Border.Effect>
      <Grid>
        <Thumb x:Name="DashboardMoveThumb"
               Style="{StaticResource MoveThumbStyle}"
               VerticalAlignment="Top"
               Height="10"
               Margin="48,2,48,0"
               HorizontalAlignment="Stretch"
               Panel.ZIndex="2"
               DragStarted="MoveThumb_DragStarted"
               DragDelta="MoveThumb_DragDelta"
               DragCompleted="MoveThumb_DragCompleted"/>
        <views:SettingsPanel x:Name="SettingsPanelControl"
                             Width="460"
                             MinWidth="380"
                             MinHeight="400"/>
        <Thumb x:Name="ResizeGrip"
               Style="{StaticResource ResizeGripStyle}"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,4,4"
               DragStarted="ResizeGrip_DragStarted"
               DragDelta="ResizeGrip_DragDelta"
               DragCompleted="ResizeGrip_DragCompleted"/>
      </Grid>
    </Border>

  </Grid>
</Window>
