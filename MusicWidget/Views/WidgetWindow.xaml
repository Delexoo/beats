<Window x:Class="MusicWidget.Views.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MusicWidget.Views"
        Title="Beats"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        FontFamily="{StaticResource Font.Body}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

  <Grid x:Name="RootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Pill bar -->
    <Border x:Name="PillBorder"
            Grid.Row="0"
            Style="{StaticResource WidgetPillBar}"
            HorizontalAlignment="Left"
            MouseEnter="PillBorder_MouseEnter"
            MouseLeave="PillBorder_MouseLeave">
        <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="52"/>
          <ColumnDefinition Width="112"/>
          <ColumnDefinition Width="102"/>
        </Grid.ColumnDefinitions>

        <!-- Hover: loop + settings (clipped reveal, matches website .pill-hover-controls) -->
        <Border x:Name="HoverControlsClip"
                Grid.Column="0"
                Width="0"
                ClipToBounds="True"
                VerticalAlignment="Center"
                HorizontalAlignment="Left">
          <StackPanel x:Name="HoverControlsPanel"
                      Orientation="Vertical"
                      Width="24"
                      Margin="0,0,6,0"
                      Opacity="0"
                      IsHitTestVisible="False">
            <Button x:Name="LoopButton"
                    Style="{StaticResource WhiteCircleButton.Utility}"
                    ToolTip="Loop current song"
                    Click="Loop_Click">
              <Grid Width="12" Height="12">
                <Rectangle x:Name="LoopIconRect">
                  <Rectangle.Fill>
                    <SolidColorBrush Color="#0A0A0A"/>
                  </Rectangle.Fill>
                  <Rectangle.OpacityMask>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/loop.png"
                                Stretch="Uniform"/>
                  </Rectangle.OpacityMask>
                </Rectangle>
              </Grid>
            </Button>
            <Button x:Name="GearButton"
                    Style="{StaticResource WhiteCircleButton.Utility}"
                    Margin="0,6,0,0"
                    ToolTip="Dashboard"
                    Click="Gear_Click">
              <Path Data="{StaticResource Icon.Gear}"
                    Fill="{StaticResource Brush.WidgetIcon}"
                    Stretch="Uniform"
                    Width="14" Height="14"/>
            </Button>
          </StackPanel>
        </Border>

        <!-- Album art (drag handle) -->
        <Grid Grid.Column="1"
              Width="52" Height="52"
              Margin="0,0,12,0"
              VerticalAlignment="Center"
              HorizontalAlignment="Left">
          <Border x:Name="AlbumArtBorder"
                  Width="52"
                  Height="52"
                  CornerRadius="8"
                  Background="{StaticResource Brush.WidgetArt}"
                  ClipToBounds="True"
                  SnapsToDevicePixels="True">
            <Border.Clip>
              <RectangleGeometry Rect="0,0,52,52" RadiusX="8" RadiusY="8"/>
            </Border.Clip>
            <Grid>
              <TextBlock x:Name="AlbumArtInitials"
                         Text="♪"
                         Foreground="{StaticResource Brush.TextDim}"
                         FontFamily="{StaticResource Font.Display}"
                         FontWeight="SemiBold"
                         FontSize="18"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
              <Image x:Name="AlbumArtImage"
                     Visibility="Collapsed"
                     Stretch="UniformToFill"
                     RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>
          </Border>
          <Thumb Style="{StaticResource MoveThumbStyle}"
                 DragStarted="MoveThumb_DragStarted"
                 DragDelta="MoveThumb_DragDelta"
                 DragCompleted="MoveThumb_DragCompleted"/>
        </Grid>

        <!-- Track info (fixed width — matches website .pill-info) -->
        <StackPanel Grid.Column="2"
                    Width="112"
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left">
          <TextBlock x:Name="TrackTitle"
                     Text="Nothing playing"
                     Width="112"
                     Foreground="White"
                     FontFamily="{StaticResource Font.Body}"
                     FontWeight="SemiBold"
                     FontSize="13.5"
                     TextTrimming="CharacterEllipsis"
                     TextWrapping="NoWrap"/>
          <TextBlock x:Name="TrackArtist"
                     Text=""
                     Width="112"
                     Foreground="{StaticResource Brush.WidgetArtist}"
                     FontFamily="{StaticResource Font.Body}"
                     FontSize="11.5"
                     Margin="0,2,0,0"
                     TextTrimming="CharacterEllipsis"
                     TextWrapping="NoWrap"/>
        </StackPanel>

        <!-- Transport controls -->
        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    Width="102"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left">
          <Button x:Name="PrevButton"
                  Style="{StaticResource WhiteCircleButton.Small}"
                  ToolTip="Previous"
                  Click="Prev_Click">
            <Path Data="{StaticResource Icon.Previous}"
                  Fill="{StaticResource Brush.WidgetIcon}"
                  Stretch="Uniform"
                  Width="13" Height="13"/>
          </Button>

          <Button x:Name="PlayPauseButton"
                  Style="{StaticResource WhiteCircleButton.Large}"
                  Margin="6,0"
                  ToolTip="Play / Pause"
                  Click="PlayPause_Click">
            <Path x:Name="PlayPauseIcon"
                  Data="{StaticResource Icon.Play}"
                  Fill="{StaticResource Brush.WidgetIcon}"
                  Stretch="Uniform"
                  Width="16" Height="16"/>
          </Button>

          <Button x:Name="NextButton"
                  Style="{StaticResource WhiteCircleButton.Small}"
                  ToolTip="Next"
                  Click="Next_Click">
            <Path Data="{StaticResource Icon.Next}"
                  Fill="{StaticResource Brush.WidgetIcon}"
                  Stretch="Uniform"
                  Width="13" Height="13"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Settings panel host (animated expand) -->
    <Border x:Name="SettingsHost"
            Grid.Row="1"
            Margin="0,6,0,0"
            HorizontalAlignment="Stretch"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="14"
            Height="0"
            Visibility="Collapsed"
            ClipToBounds="True">
      <Border.Effect>
        <DropShadowEffect Color="Black" Opacity="0.55" BlurRadius="20" ShadowDepth="5"/>
      </Border.Effect>
      <Grid>
        <Thumb x:Name="DashboardMoveThumb"
               Style="{StaticResource MoveThumbStyle}"
               VerticalAlignment="Top"
               Height="10"
               Margin="48,2,48,0"
               HorizontalAlignment="Stretch"
               Panel.ZIndex="2"
               DragStarted="MoveThumb_DragStarted"
               DragDelta="MoveThumb_DragDelta"
               DragCompleted="MoveThumb_DragCompleted"/>
        <views:SettingsPanel x:Name="SettingsPanelControl"
                             Width="460"
                             MinWidth="380"
                             MinHeight="400"/>
        <Thumb x:Name="ResizeGrip"
               Style="{StaticResource ResizeGripStyle}"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,4,4"
               DragStarted="ResizeGrip_DragStarted"
               DragDelta="ResizeGrip_DragDelta"
               DragCompleted="ResizeGrip_DragCompleted"/>
      </Grid>
    </Border>

  </Grid>
</Window>
