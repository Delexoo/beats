<Window x:Class="MusicWidget.Views.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MusicWidget.Views"
        Title="Beats"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        FontFamily="{StaticResource Font.Body}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

  <Grid x:Name="RootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Pill bar (row host stretches to dashboard width so the pill can center above it) -->
    <Grid x:Name="PillRowHost"
          Grid.Row="0"
          HorizontalAlignment="Stretch">
    <Grid x:Name="PillStack"
          HorizontalAlignment="Left">
      <!-- Rounded shadow layer — DropShadowEffect ignores CornerRadius and leaves square corners. -->
      <Border CornerRadius="14"
              Margin="0,5,2,0"
              IsHitTestVisible="False"
              SnapsToDevicePixels="True"
              UseLayoutRounding="True">
        <Border.Background>
          <SolidColorBrush Color="#40000000"/>
        </Border.Background>
      </Border>
    <Border x:Name="PillBorder"
            Style="{StaticResource WidgetPillBar}"
            HorizontalAlignment="Left"
            MouseEnter="PillBorder_MouseEnter"
            MouseLeave="PillBorder_MouseLeave">
        <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="82"/>
        </Grid.ColumnDefinitions>

        <!-- Hover: loop + settings (clipped reveal, matches website .pill-hover-controls) -->
        <Border x:Name="HoverControlsClip"
                Grid.Column="0"
                Width="0"
                ClipToBounds="True"
                VerticalAlignment="Center"
                HorizontalAlignment="Left">
          <StackPanel x:Name="HoverControlsPanel"
                      Orientation="Vertical"
                      Width="20"
                      Margin="0,0,5,0"
                      Opacity="1"
                      IsHitTestVisible="False">
            <Button x:Name="LoopButton"
                    Style="{StaticResource WhiteCircleButton.Utility}"
                    ToolTip="Loop current song (off)"
                    ToolTipService.InitialShowDelay="400"
                    ToolTipService.BetweenShowDelay="300"
                    ToolTipService.ShowDuration="5000"
                    Click="Loop_Click">
              <Grid Width="10" Height="10">
                <Rectangle x:Name="LoopIconRect">
                  <Rectangle.Fill>
                    <SolidColorBrush Color="#0A0A0A"/>
                  </Rectangle.Fill>
                  <Rectangle.OpacityMask>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/loop.png"
                                Stretch="Uniform"/>
                  </Rectangle.OpacityMask>
                </Rectangle>
              </Grid>
            </Button>
            <Button x:Name="GearButton"
                    Style="{StaticResource WhiteCircleButton.Utility}"
                    Margin="0,4,0,0"
                    ToolTip="Open dashboard"
                    ToolTipService.InitialShowDelay="400"
                    ToolTipService.BetweenShowDelay="300"
                    ToolTipService.ShowDuration="5000"
                    Click="Gear_Click">
              <Path Data="{StaticResource Icon.Gear}"
                    Fill="{StaticResource Brush.WidgetIcon}"
                    Stretch="Uniform"
                    Width="12" Height="12"/>
            </Button>
          </StackPanel>
        </Border>

        <!-- Album art + track info -->
        <Grid Grid.Column="1"
              VerticalAlignment="Center"
              HorizontalAlignment="Left"
              Margin="0,0,12,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="44"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="120"/>
          </Grid.ColumnDefinitions>

          <!-- Album art (drag handle) -->
          <Grid Grid.Column="0"
                Width="44" Height="44"
                VerticalAlignment="Center"
                HorizontalAlignment="Left">
            <Border x:Name="AlbumArtBorder"
                    Width="44"
                    Height="44"
                    CornerRadius="6"
                    Background="{StaticResource Brush.WidgetArt}"
                    ClipToBounds="True"
                    SnapsToDevicePixels="True">
              <Grid Width="44" Height="44">
                <Border x:Name="AlbumArtImageHost"
                        Visibility="Collapsed"
                        CornerRadius="6"
                        ClipToBounds="True">
                  <Border.Background>
                    <ImageBrush x:Name="AlbumArtBrush"
                                Stretch="UniformToFill"
                                AlignmentX="Center"
                                AlignmentY="Center"/>
                  </Border.Background>
                </Border>
                <TextBlock x:Name="AlbumArtInitials"
                           Text="♪"
                           Foreground="{StaticResource Brush.TextDim}"
                           FontFamily="{StaticResource Font.Display}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Grid>
            </Border>
            <Thumb Style="{StaticResource MoveThumbStyle}"
                   DragStarted="MoveThumb_DragStarted"
                   DragDelta="MoveThumb_DragDelta"
                   DragCompleted="MoveThumb_DragCompleted"/>
          </Grid>

          <!-- Track details (right of cover; ellipsis when too long) -->
          <StackPanel Grid.Column="2"
                      Width="120"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Left">
            <TextBlock x:Name="TrackTitle"
                       Text="Nothing playing"
                       MaxWidth="120"
                       Foreground="White"
                       FontFamily="{StaticResource Font.Body}"
                       FontWeight="SemiBold"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"/>
          <TextBlock x:Name="TrackArtist"
                     Text=""
                     MaxWidth="120"
                       Foreground="{StaticResource Brush.WidgetArtist}"
                       FontFamily="{StaticResource Font.Body}"
                       FontSize="10"
                       Margin="0,2,0,0"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"/>
          </StackPanel>
        </Grid>

        <!-- Transport controls -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Width="82"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left">
          <Button x:Name="PrevButton"
                  Style="{StaticResource WhiteCircleButton.Small}"
                  ToolTip="Previous"
                  Click="Prev_Click">
            <Path Data="{StaticResource Icon.Previous}"
                  Fill="{StaticResource Brush.WidgetIcon}"
                  Stretch="Uniform"
                  Width="11" Height="11"/>
          </Button>

          <Button x:Name="PlayPauseButton"
                  Style="{StaticResource WhiteCircleButton.Large}"
                  Margin="4,0"
                  ToolTip="Play / Pause"
                  Click="PlayPause_Click">
            <Path x:Name="PlayPauseIcon"
                  Data="{StaticResource Icon.Play}"
                  Fill="{StaticResource Brush.WidgetIcon}"
                  Stretch="Uniform"
                  Width="14" Height="14"/>
          </Button>

          <Button x:Name="NextButton"
                  Style="{StaticResource WhiteCircleButton.Small}"
                  ToolTip="Next"
                  Click="Next_Click">
            <Path Data="{StaticResource Icon.Next}"
                  Fill="{StaticResource Brush.WidgetIcon}"
                  Stretch="Uniform"
                  Width="11" Height="11"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>
    </Grid>
    </Grid>

    <!-- Settings panel host (animated expand) -->
    <Border x:Name="SettingsHost"
            Grid.Row="1"
            Margin="0,6,0,0"
            HorizontalAlignment="Stretch"
            MinWidth="{Binding ElementName=SettingsPanelControl, Path=Width}"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="14"
            Height="0"
            Visibility="Collapsed"
            ClipToBounds="True">
      <Border.Effect>
        <DropShadowEffect Color="Black" Opacity="0.55" BlurRadius="20" ShadowDepth="5"/>
      </Border.Effect>
      <Grid>
        <Thumb x:Name="DashboardMoveThumb"
               Style="{StaticResource MoveThumbStyle}"
               VerticalAlignment="Top"
               Height="10"
               Margin="48,2,48,0"
               HorizontalAlignment="Stretch"
               Panel.ZIndex="2"
               DragStarted="MoveThumb_DragStarted"
               DragDelta="MoveThumb_DragDelta"
               DragCompleted="MoveThumb_DragCompleted"/>
        <views:SettingsPanel x:Name="SettingsPanelControl"
                             HorizontalAlignment="Stretch"
                             MinWidth="380"
                             MinHeight="400"/>
        <Thumb x:Name="ResizeGrip"
               Style="{StaticResource ResizeGripStyle}"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,4,4"
               DragStarted="ResizeGrip_DragStarted"
               DragDelta="ResizeGrip_DragDelta"
               DragCompleted="ResizeGrip_DragCompleted"/>
      </Grid>
    </Border>

  </Grid>
</Window>
