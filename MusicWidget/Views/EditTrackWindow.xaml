<Window x:Class="MusicWidget.Views.EditTrackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit song"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="380"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        ShowInTaskbar="False"
        FontFamily="{StaticResource Font.Body}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

  <Border Background="{StaticResource Brush.Surface}"
          BorderBrush="{StaticResource Brush.Border}"
          BorderThickness="1"
          CornerRadius="12"
          Padding="16">
    <Border.Effect>
      <DropShadowEffect Color="Black" Opacity="0.45" BlurRadius="20" ShadowDepth="4"/>
    </Border.Effect>
    <StackPanel>
      <TextBlock Text="Edit song"
                 Foreground="{StaticResource Brush.Text}"
                 FontFamily="{StaticResource Font.Display}"
                 FontWeight="SemiBold"
                 FontSize="14"
                 Margin="0,0,0,12"/>

      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Width="72"
                Height="72"
                CornerRadius="8"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                ClipToBounds="True">
          <Grid>
            <Image x:Name="CoverPreview"
                   Stretch="UniformToFill"
                   Visibility="Collapsed"/>
            <TextBlock x:Name="CoverPlaceholder"
                       Text="?"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource Brush.TextDim}"
                       FontSize="20"
                       FontWeight="SemiBold"/>
          </Grid>
        </Border>

        <StackPanel Grid.Column="1"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center">
          <Button Style="{StaticResource FlatButton}"
                  Content="Choose cover..."
                  Click="ChooseCover_Click"
                  HorizontalAlignment="Left"/>
          <TextBlock Text="Optional"
                     Foreground="{StaticResource Brush.TextDim}"
                     FontSize="10"
                     Margin="0,4,0,0"/>
        </StackPanel>
      </Grid>

      <TextBlock Text="Artist"
                 Foreground="{StaticResource Brush.TextDim}"
                 FontSize="11"
                 Margin="0,0,0,4"/>
      <TextBox x:Name="ArtistBox"
               Style="{StaticResource DarkTextBox}"
               Margin="0,0,0,10"/>

      <TextBlock Text="Song name"
                 Foreground="{StaticResource Brush.TextDim}"
                 FontSize="11"
                 Margin="0,0,0,4"/>
      <TextBox x:Name="TitleBox"
               Style="{StaticResource DarkTextBox}"
               KeyDown="TitleBox_KeyDown"/>

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,14,0,0">
        <Button Style="{StaticResource FlatButton}"
                Content="Cancel"
                Click="Cancel_Click"/>
        <Button Style="{StaticResource PrimaryButton}"
                Margin="6,0,0,0"
                Content="Save"
                Click="Save_Click"
                IsDefault="True"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
