<Window x:Class="MusicWidget.Views.HideToggleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beats Toggle"
        Width="40"
        Height="12"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        ShowActivated="False"
        Focusable="False"
        FontFamily="{StaticResource Font.Body}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

  <Border x:Name="Bg"
          Background="{StaticResource Brush.Bg.Pill}"
          BorderBrush="{StaticResource Brush.Border}"
          BorderThickness="1,0,1,1"
          CornerRadius="0,0,10,10"
          Cursor="Hand"
          MouseLeftButtonDown="Bg_MouseLeftButtonDown">
    <Border.Effect>
      <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="10" ShadowDepth="2"/>
    </Border.Effect>
    <Path x:Name="ChevronPath"
          Data="{StaticResource Icon.ChevronDown}"
          Fill="{StaticResource Brush.Blue}"
          Stretch="Uniform"
          Width="12" Height="6"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          RenderTransformOrigin="0.5,0.5">
      <Path.RenderTransform>
        <RotateTransform x:Name="ChevronRotate" Angle="0"/>
      </Path.RenderTransform>
    </Path>
  </Border>
</Window>
