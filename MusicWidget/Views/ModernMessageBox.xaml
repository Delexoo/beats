<Window x:Class="MusicWidget.Views.ModernMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beats"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="400"
        MinWidth="320"
        MaxWidth="540"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{StaticResource Font.Body}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Topmost="True">
  <Border Background="{StaticResource Brush.Surface}"
          BorderBrush="{StaticResource Brush.Border}"
          BorderThickness="1"
          CornerRadius="12">
    <Border.Effect>
      <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="26" ShadowDepth="6"/>
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Title bar (drag handle + close) -->
      <Grid Grid.Row="0"
            Background="Transparent"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="TitleText"
                   Grid.Column="0"
                   Margin="18,12,8,0"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource Brush.Text}"
                   FontFamily="{StaticResource Font.Display}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis"/>
        <Button Grid.Column="1"
                Style="{StaticResource IconGhostButton}"
                Width="28" Height="28"
                Margin="0,8,8,0"
                ToolTip="Close"
                Click="CloseButton_Click">
          <Path Data="{StaticResource Icon.Close}"
                Fill="{StaticResource Brush.TextDim}"
                Stretch="Uniform"
                Width="10" Height="10"/>
        </Button>
      </Grid>

      <!-- Body -->
      <Grid Grid.Row="1" Margin="18,10,18,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0"
                x:Name="IconBadge"
                Width="42" Height="42"
                CornerRadius="21"
                VerticalAlignment="Top"
                Margin="0,2,14,0">
          <Path x:Name="IconPath"
                Stretch="Uniform"
                Width="20" Height="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        </Border>
        <TextBlock x:Name="MessageText"
                   Grid.Column="1"
                   Foreground="{StaticResource Brush.Text}"
                   FontSize="12.5"
                   LineHeight="19"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   Margin="0,2,0,2"/>
      </Grid>

      <!-- Buttons -->
      <StackPanel x:Name="ButtonRow"
                  Grid.Row="2"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="18,14,18,16"/>
    </Grid>
  </Border>
</Window>
